<style>
:root {
  --nx-bg:      rgba(245,243,239,0.92);
  --nx-ink:     #1a1714;
  --nx-muted:   #78716c;
  --nx-navy:    #1e3a5f;
  --nx-amber:   #d97706;
  --nx-amber-lt:#fef3c7;
  --nx-border:  rgba(28,25,23,0.09);
  --nx-white:   #ffffff;
  --nx-ease:    cubic-bezier(0.34,1.56,0.64,1);
  --nx-std:     cubic-bezier(0.4,0,0.2,1);
}

/* ── BASE ── */
.nx-nav {
  background: var(--nx-bg);
  backdrop-filter: blur(28px) saturate(200%);
  -webkit-backdrop-filter: blur(28px) saturate(200%);
  border-bottom: 1px solid var(--nx-border);
  padding: 0;
  height: 64px;
  z-index: 1050;
  font-family: 'Inter', system-ui, sans-serif;
  transition: box-shadow .4s var(--nx-std), background .4s;
}
.nx-nav .container-fluid { height: 100%; align-items: center; }
.nx-nav.nx-scrolled {
  background: rgba(245,243,239,.98);
  box-shadow: 0 1px 0 rgba(0,0,0,.05), 0 10px 40px -10px rgba(28,25,23,.12);
}

/* ── LOGO ── */
.nx-brand {
  display: flex;
  align-items: center;
  gap: 11px;
  text-decoration: none;
  white-space: nowrap;
}
.nx-brand:hover { text-decoration: none; }

/* logo mark */
.nx-logo {
  position: relative;
  width: 34px; height: 34px;
  flex-shrink: 0;
}
.nx-logo-inner {
  width: 34px; height: 34px;
  background: var(--nx-navy);
  border-radius: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  transition: transform .4s var(--nx-ease), border-radius .35s var(--nx-std);
}
.nx-brand:hover .nx-logo-inner {
  border-radius: 14px;
  transform: rotate(-6deg);
}

/* the D and B letters inside */
.nx-logo-d, .nx-logo-b {
  font-size: .88rem;
  font-weight: 900;
  line-height: 1;
  letter-spacing: -.06em;
  font-family: 'Inter', system-ui, sans-serif;
}
.nx-logo-d {
  color: #fff;
  position: relative;
  z-index: 1;
}
.nx-logo-b {
  color: var(--nx-amber);
  position: relative;
  z-index: 1;
  margin-left: -1px;
}

/* amber corner notch */
.nx-logo-notch {
  position: absolute;
  bottom: -4px; right: -4px;
  width: 13px; height: 13px;
  background: var(--nx-amber);
  border-radius: 4px 0 4px 0;
  transition: transform .35s var(--nx-ease), width .3s, height .3s;
}
.nx-brand:hover .nx-logo-notch {
  transform: scale(1.25) rotate(8deg);
}

/* brand wordmark */
.nx-brand-text {
  display: flex;
  align-items: baseline;
  gap: 0;
  line-height: 1;
}
.nx-brand-daksh {
  font-size: 1.05rem;
  font-weight: 500;
  letter-spacing: -.035em;
  color: var(--nx-ink);
  transition: color .25s;
}
.nx-brand-bharat {
  font-size: 1.05rem;
  font-weight: 800;
  letter-spacing: -.04em;
  color: var(--nx-amber);
  transition: letter-spacing .35s var(--nx-std);
}
.nx-brand:hover .nx-brand-daksh { color: var(--nx-navy); }
.nx-brand:hover .nx-brand-bharat { letter-spacing: -.01em; }

/* ── CENTER ISLAND ── */
.nx-island {
  position: absolute; left: 50%; transform: translateX(-50%);
  display: flex; align-items: center; gap: 3px;
  background: var(--nx-white);
  border: 1px solid var(--nx-border);
  border-radius: 100px;
  padding: 5px;
  box-shadow: 0 1px 4px rgba(0,0,0,.05), 0 0 0 0 rgba(217,119,6,0);
  transition: box-shadow .3s var(--nx-std);
}
.nx-island:hover {
  box-shadow: 0 2px 12px rgba(0,0,0,.07), 0 0 0 3px rgba(217,119,6,.07);
}

.nx-item {
  font-size: .81rem; font-weight: 600;
  color: var(--nx-muted);
  text-decoration: none;
  padding: 7px 17px;
  border-radius: 100px;
  letter-spacing: -.01em;
  transition: color .2s var(--nx-std), background .2s var(--nx-std);
  position: relative; overflow: hidden;
  white-space: nowrap;
}
.nx-item:hover  { color: var(--nx-ink); background: rgba(28,25,23,.05); }
.nx-item.nx-active {
  color: var(--nx-navy);
  background: rgba(30,58,95,.08);
  font-weight: 700;
}
.nx-item:active {
  transform: scale(.95);
  background: var(--nx-amber-lt);
  color: var(--nx-amber);
}

/* ripple */
.nx-item .nx-rip {
  position: absolute; border-radius: 50%;
  background: rgba(217,119,6,.15);
  transform: scale(0);
  animation: nxRipple .45s ease forwards;
  pointer-events: none;
}
@keyframes nxRipple { to { transform: scale(4); opacity: 0; } }

/* ── RIGHT ── */
.nx-right { display: flex; align-items: center; gap: 7px; }

.nx-ghost {
  font-size: .81rem; font-weight: 600;
  color: var(--nx-ink);
  text-decoration: none;
  padding: 8px 16px;
  border-radius: 100px;
  border: 1px solid var(--nx-border);
  background: transparent;
  letter-spacing: -.01em;
  transition: background .2s, color .2s, transform .15s var(--nx-ease), border-color .2s;
  display: inline-flex; align-items: center; gap: 6px;
  white-space: nowrap;
}
.nx-ghost:hover  {
  background: var(--nx-white);
  border-color: rgba(28,25,23,.16);
  color: var(--nx-ink);
  box-shadow: 0 2px 8px rgba(0,0,0,.06);
}
.nx-ghost:active { transform: scale(.95); }

.nx-solid {
  font-size: .81rem; font-weight: 700;
  color: #fff !important;
  text-decoration: none;
  padding: 8px 20px;
  border-radius: 100px;
  background: var(--nx-navy);
  letter-spacing: -.01em;
  transition: transform .15s var(--nx-ease), box-shadow .25s;
  position: relative; overflow: hidden;
  display: inline-block;
  white-space: nowrap;
}
.nx-solid::before {
  content: '';
  position: absolute; inset: 0; border-radius: 100px;
  background: var(--nx-amber);
  transform: translateY(100%);
  transition: transform .28s var(--nx-std);
}
.nx-solid span { position: relative; z-index: 1; }
.nx-solid:hover {
  box-shadow: 0 4px 18px rgba(30,58,95,.25);
  transform: translateY(-1px);
  color: #fff !important;
}
.nx-solid:hover::before { transform: translateY(0); }
.nx-solid:active { transform: scale(.95) translateY(0); box-shadow: none; }

/* ── AVATAR PILL ── */
.nx-avatar-wrap {
  display: flex; align-items: center; gap: 9px;
  background: var(--nx-white);
  border: 1px solid var(--nx-border);
  border-radius: 100px;
  padding: 4px 12px 4px 4px;
  cursor: pointer;
  transition: border-color .25s, box-shadow .25s, transform .15s var(--nx-ease);
}
.nx-avatar-wrap::after { display: none !important; }
.nx-avatar-wrap:hover  {
  border-color: rgba(217,119,6,.45);
  box-shadow: 0 3px 14px rgba(217,119,6,.12);
}
.nx-avatar-wrap:active { transform: scale(.97); }

.nx-av-img {
  width: 28px; height: 28px;
  border-radius: 50%; overflow: hidden; flex-shrink: 0;
  border: 2px solid var(--nx-amber);
}
.nx-av-img img { width: 100%; height: 100%; object-fit: cover; display: block; }

.nx-av-meta { display: flex; flex-direction: column; line-height: 1.2; }
.nx-av-name {
  font-size: .79rem; font-weight: 700;
  color: var(--nx-ink); letter-spacing: -.01em;
}

.nx-av-role {
  font-size: .6rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: .5px;
  display: flex; align-items: center; gap: 3px;
}
.nx-role-company  { color: #0e7490; }
.nx-role-employee { color: #d97706; }
.nx-role-user     { color: #7c3aed; }

.nx-chevron {
  color: var(--nx-muted);
  transition: transform .25s var(--nx-std);
  margin-left: 2px; flex-shrink: 0;
}
.nx-avatar-wrap[aria-expanded="true"] .nx-chevron { transform: rotate(180deg); }

/* ── DROPDOWN ── */
.nx-menu {
  border: 1px solid var(--nx-border) !important;
  border-radius: 18px !important;
  padding: 8px !important;
  margin-top: 10px !important;
  background: rgba(255,255,255,.97) !important;
  backdrop-filter: blur(20px);
  box-shadow: 0 20px 52px -8px rgba(28,25,23,.15) !important;
  min-width: 220px;
  animation: nxMenuIn .2s var(--nx-ease) both;
}
@keyframes nxMenuIn {
  from { opacity: 0; transform: translateY(-7px) scale(.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

.nx-menu-header {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 12px 12px;
}
.nx-mh-av { width: 36px; height: 36px; border-radius: 50%; overflow: hidden; flex-shrink: 0; }
.nx-mh-av img { width: 100%; height: 100%; object-fit: cover; display: block; }
.nx-mh-name {
  font-size: .85rem; font-weight: 700;
  color: var(--nx-ink); margin: 0 0 3px; letter-spacing: -.02em;
}
.nx-mh-badge {
  font-size: .62rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: .6px;
  padding: 2px 9px; border-radius: 100px;
}
.nx-mh-badge.nx-role-company  { background: #ecfeff; color: #0e7490; }
.nx-mh-badge.nx-role-employee { background: #fef3c7; color: #92400e; }
.nx-mh-badge.nx-role-user     { background: #f5f3ff; color: #6d28d9; }

.nx-menu-sep { height: 1px; background: var(--nx-border); margin: 4px 8px; }

.nx-mi {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 12px; border-radius: 10px;
  font-size: .83rem; font-weight: 600;
  color: var(--nx-ink);
  transition: background .15s, transform .15s var(--nx-ease), color .15s;
}
.nx-mi svg { color: var(--nx-muted); flex-shrink: 0; transition: color .15s; }
.nx-mi:hover   { background: rgba(28,25,23,.05); transform: translateX(3px); }
.nx-mi:hover svg { color: var(--nx-navy); }
.nx-mi:active  { background: var(--nx-amber-lt); color: var(--nx-amber); }
.nx-mi-out:hover   { background: #fef2f2; color: #dc2626; }
.nx-mi-out:hover svg { color: #dc2626; }
.nx-mi-out:active  { background: #fee2e2; }

/* ── MOBILE TOGGLE ── */
.nx-mob-toggle {
  width: 38px; height: 38px;
  background: var(--nx-white);
  border: 1px solid var(--nx-border) !important;
  border-radius: 10px;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 5px; padding: 0;
  transition: background .2s, transform .15s var(--nx-ease);
}
.nx-mob-toggle span {
  display: block; width: 16px; height: 1.5px;
  background: var(--nx-ink); border-radius: 2px;
  transition: transform .3s var(--nx-std), opacity .3s, width .3s;
}
.nx-mob-toggle:hover { background: rgba(28,25,23,.04); }
.nx-mob-toggle:active { transform: scale(.9); }
.nx-mob-toggle[aria-expanded="true"] span:first-child { transform: translateY(3.5px) rotate(45deg); }
.nx-mob-toggle[aria-expanded="true"] span:last-child  { transform: translateY(-3.5px) rotate(-45deg); }

/* ── MOBILE PANEL ── */
.nx-mob-panel { border-top: 1px solid var(--nx-border); }
.nx-mob-inner {
  padding: 12px 16px 24px;
  display: flex; flex-direction: column; gap: 2px;
  background: var(--nx-white);
}
.nx-mob-link {
  font-size: .88rem; font-weight: 600;
  color: var(--nx-muted);
  text-decoration: none;
  padding: 11px 14px;
  border-radius: 10px;
  transition: color .2s, background .2s;
}
.nx-mob-link:hover  { color: var(--nx-ink); background: rgba(28,25,23,.04); }
.nx-mob-link:active { background: var(--nx-amber-lt); color: var(--nx-amber); }
.nx-mob-out:hover   { color: #dc2626; background: #fef2f2; }
.nx-mob-divider { height: 1px; background: var(--nx-border); margin: 6px 0; }
.nx-mob-cta { margin-top: 6px; text-align: center; display: block; }

.nx-mob-user {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 14px; margin-bottom: 4px;
  background: rgba(28,25,23,.03); border-radius: 12px;
}
.nx-mob-user img { width: 36px; height: 36px; border-radius: 50%; }
.nx-mob-user p   { font-size: .9rem; font-weight: 700; color: var(--nx-ink); margin: 0 0 2px; }
</style>

<script>
(function(){
  // scroll shadow
  window.addEventListener('scroll', function(){
    document.querySelector('.nx-nav').classList.toggle('nx-scrolled', scrollY > 8);
  });

  // active link + ripple
  document.querySelectorAll('.nx-item').forEach(function(el){
    if(el.href === location.href) el.classList.add('nx-active');

    el.addEventListener('click', function(e){
      var r = document.createElement('span');
      var b = el.getBoundingClientRect();
      var s = Math.max(b.width, b.height);
      r.className = 'nx-rip';
      r.style.cssText = 'width:'+s+'px;height:'+s+'px;left:'+(e.clientX-b.left-s/2)+'px;top:'+(e.clientY-b.top-s/2)+'px;';
      el.appendChild(r);
      setTimeout(function(){ r.remove(); }, 450);
    });
  });
})();
</script>
