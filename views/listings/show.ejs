<% layout("/layouts/boilerplate.ejs") %>

<style>
  :root {
    --primary-blue: #0F62FE;
    --success-green: #10b981;
    --bg-light: #f8fafc;
  }

  .job-details-wrapper {
    background-color: var(--bg-light);
    min-height: 100vh;
    padding-bottom: 5rem;
  }
  .job-card {
    background: #ffffff;
    border-radius: 16px;
    border: 1px solid #e5e7eb;
    overflow: hidden;
  }
  .job-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
  }
  .price-badge-modern {
    background-color: #eff6ff;
    color: var(--primary-blue);
    font-size: 1.4rem;
    padding: 12px 24px;
    border-radius: 12px;
    font-weight: 800;
    border: 1px solid rgba(15, 98, 254, 0.1);
  }
  .provider-card {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    transition: 0.3s;
  }
  .star-rating input:checked ~ label, 
  .star-rating label:hover, 
  .star-rating label:hover ~ label {
    color: #ffc107 !important;
  }
</style>

<div class="job-details-wrapper pt-4">
  <div class="container col-md-9 mx-auto">
    <a href="/home/listings" class="text-decoration-none text-muted mb-4 d-inline-block fw-bold">
      <i class="bi bi-arrow-left"></i> Back to Marketplace
    </a>

    <div class="card job-card shadow-sm mb-5">
      <div class="position-absolute m-3" style="z-index: 2;">
        <span class="badge <%= listing.category === 'Job' ? 'bg-primary' : 'bg-warning text-dark' %> px-3 py-2 fs-6 rounded-pill shadow">
          <%= listing.category === 'Job' ? 'Recruitment' : 'Professional Service' %>
        </span>
      </div>

      <% if(listing.imageUrl && listing.imageUrl.url) { %>
        <img src="<%= listing.imageUrl.url %>" alt="<%= listing.title %>" class="job-image" />
      <% } else { %>
        <img src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" class="job-image" />
      <% } %>

      <div class="card-body p-4 p-md-5">
        <div class="row align-items-center mb-4">
          <div class="col-lg-8">
            <h1 class="fw-extrabold mb-1 display-5 text-dark"><%= listing.title %></h1>
            <p class="fs-5 text-muted mb-0">
              <i class="bi bi-person-workspace text-primary me-2"></i>By <strong><%= listing.providerName %></strong>
            </p>
          </div>
          <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
            <div class="price-badge-modern">
              ₹<%= (listing.price) ? listing.price.toLocaleString("en-IN") : "0" %> 
              <span class="fs-6 fw-normal text-muted">/ <%= listing.priceUnit %></span>
            </div>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-3 mb-5">
          <span class="badge bg-light text-dark border p-2 px-3 fs-6"><i class="bi bi-grid-fill me-1 text-primary"></i> <%= listing.type %></span>
          <span class="badge bg-light text-dark border p-2 px-3 fs-6"><i class="bi bi-geo-alt-fill me-1 text-danger"></i> <%= listing.location %></span>
          <span class="badge bg-light text-dark border p-2 px-3 fs-6"><i class="bi bi-calendar-event me-1 text-success"></i> Posted <%= new Date(listing.createdAt).toLocaleDateString() %></span>
        </div>

        <h4 class="fw-bold mb-3 border-start border-4 border-primary ps-3">Details & Scope</h4>
        <p class="fs-5 text-secondary lh-lg mb-5" style="white-space: pre-wrap;"><%= listing.description %></p>

        <% if(listing.tags && listing.tags.length > 0) { %>
          <h4 class="fw-bold mb-3"><%= listing.category === 'Job' ? 'Skill Requirements' : 'Service Specialties' %></h4>
          <div class="mb-5">
            <% for(let tag of listing.tags) { %>
              <span class="badge rounded-pill bg-dark text-white me-2 mb-2 p-2 px-3"><%= tag %></span>
            <% } %>
          </div>
        <% } %>

        <h4 class="fw-bold mb-3">Provider Information</h4>
        <div class="card provider-card p-4 bg-white mb-4">
          <div class="row align-items-center">
            <div class="col-md-7">
              <% if(listing.owner) { %>
                <h5 class="fw-bold mb-1"><%= listing.owner.username %></h5>
                <p class="text-muted small mb-0">Verified Member since <%= new Date(listing.owner.joinedAt).getFullYear() %></p>
              <% } else { %>
                <h5 class="fw-bold mb-1 text-danger">Provider information unavailable</h5>
              <% } %>
            </div>
            <div class="col-md-5 text-md-end mt-3 mt-md-0">
              <% if(!currUser) { %>
                <a href="/login" class="btn btn-primary px-4 py-2">Login to Contact</a>
              <% } else if (listing.owner) { %>
                <div class="d-flex gap-2 justify-content-md-end">
                  <a href="https://wa.me/<%=listing.owner.phone%>" target="_blank" class="btn btn-outline-success"><i class="bi bi-whatsapp"></i></a>
                  
                  <% if(currUser.role === 'customer' && listing.category === 'Service') { %>
                    <form action="/home/listings/<%= listing._id %>/assign" method="POST">
                      <button class="btn btn-success px-4 shadow-sm">Book Service</button>
                    </form>
                  <% } else if(currUser.role === 'employee' && listing.category === 'Job') { %>
                    <form action="/home/listings/<%= listing._id %>/assign" method="POST">
                      <button class="btn btn-primary px-4 shadow-sm">Apply Now</button>
                    </form>
                  <% } else { %>
                    <a href="tel:+91<%=listing.owner.phone%>" class="btn btn-primary"><i class="bi bi-telephone-fill me-1"></i> Call</a>
                  <% } %>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
          <div class="d-flex gap-3 mt-5 pt-4 border-top">
            <a href="/home/listings/<%= listing._id %>/edit" class="btn btn-outline-dark px-4"><i class="bi bi-pencil-square"></i> Edit</a>
            <form method="post" action="/home/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
              <button class="btn btn-outline-danger px-4"><i class="bi bi-trash3"></i> Delete</button>
            </form>
          </div>
        <% } %>
      </div>
    </div>

    <div class="card job-card shadow-sm p-4 p-md-5">
      <h4 class="mb-4 fw-bold">User Feedback & Trust Record</h4>
      
      <% if(currUser && (currUser.role === 'customer' || currUser.role === 'employee')) { %>
        <div class="bg-light p-4 rounded-4 mb-5 border">
          <h5 class="mb-3 fs-6 fw-bold text-dark">Leave a review for <%= listing.providerName %></h5>
          <form action="/home/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
            <div class="mb-3">
              <div class="star-rating d-flex flex-row justify-content-start fs-3" style="direction: rtl;">
                <input type="radio" id="star5" name="review[rating]" value="5" required style="display: none;"/>
                <label for="star5" class="bi bi-star-fill text-muted px-1" style="cursor:pointer;"></label>
                <input type="radio" id="star4" name="review[rating]" value="4" style="display: none;"/>
                <label for="star4" class="bi bi-star-fill text-muted px-1" style="cursor:pointer;"></label>
                <input type="radio" id="star3" name="review[rating]" value="3" style="display: none;"/>
                <label for="star3" class="bi bi-star-fill text-muted px-1" style="cursor:pointer;"></label>
                <input type="radio" id="star2" name="review[rating]" value="2" style="display: none;"/>
                <label for="star2" class="bi bi-star-fill text-muted px-1" style="cursor:pointer;"></label>
                <input type="radio" id="star1" name="review[rating]" value="1" style="display: none;"/>
                <label for="star1" class="bi bi-star-fill text-muted px-1" style="cursor:pointer;"></label>
              </div>
            </div>
            <div class="mb-3">
              <textarea name="review[comment]" class="form-control border-0 shadow-sm" rows="3" placeholder="How was your experience?" required style="border-radius: 12px;"></textarea>
            </div>
            <button type="submit" class="btn btn-primary px-4 rounded-pill">Submit Review</button>
          </form>
        </div>
      <% } %>

      <% if (listing.reviews && listing.reviews.length > 0) { %>
        <div class="row g-4">
          <% listing.reviews.forEach(review => { %>
            <div class="col-md-6">
              <div class="card h-100 border-0 bg-white shadow-sm rounded-4 p-4 border border-light">
                <div class="d-flex justify-content-between align-items-center mb-3">
                  <div class="d-flex align-items-center">
                    <img src="https://ui-avatars.com/api/?name=<%= review.author.username %>&background=random" class="rounded-circle me-2" width="35">
                    <h6 class="mb-0 fw-bold"><%= review.author.username %></h6>
                  </div>
                  <span class="badge bg-warning-subtle text-dark border border-warning"><%= review.rating %> <i class="bi bi-star-fill"></i></span>
                </div>
                <p class="text-secondary small mb-3"><%= review.comment %></p>
                <div class="d-flex justify-content-between align-items-center mt-auto">
                  <small class="text-muted"><%= new Date(review.createdAt).toLocaleDateString() %></small>
                  <% if (currUser && review.author && currUser._id.equals(review.author._id)) { %>
                    <form method="post" action="/home/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=delete">
                      <button class="btn btn-sm text-danger border-0 bg-transparent"><i class="bi bi-trash3"></i></button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="text-center py-5 border rounded-4 bg-light">
          <p class="text-muted mb-0">No reviews yet. Be the first to build the trust record!</p>
        </div>
      <% } %>
    </div>
  </div>
</div>