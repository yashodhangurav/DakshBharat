<section class="lp-hero">
  <div class="lp-hero-bg" data-i18n="hero_bg">MARKET</div>
  <div class="container" style="position:relative;z-index:1;">
    <div class="lp-eyebrow">
      <span class="lp-eyebrow-dot"></span>
      <span data-i18n="eyebrow">Global Network</span>
      <span class="lp-eyebrow-dot"></span>
    </div>
    <h1>SkillBridge <span class="hi" data-i18n="hero_accent">Index</span></h1>
    <p data-i18n="hero_sub">Efficiently discovery verified talent and local opportunities.</p>

    <div class="lp-chips">
      <span class="lp-chip"><i class="bi bi-patch-check-fill"></i> <span data-i18n="chip1">Verified Professionals</span></span>
      <span class="lp-chip"><i class="bi bi-lightning-charge-fill"></i> <span data-i18n="chip2">Instant Booking</span></span>
    </div>
  </div>
</section>

<div class="fb-wrap">
  <div class="container">
    <div class="fb-inner">
      <div class="fb-search">
        <i class="bi bi-search"></i>
        <input type="text" id="searchInput" onkeyup="filterCards()" data-i18n-placeholder="search_placeholder" placeholder="Find skills or cities...">
      </div>
      <div class="fb-pills">
        <button class="fb-pill active" onclick="setCategory('All',this)" data-i18n="pill_all">All</button>
        <button class="fb-pill" onclick="setCategory('Job',this)" data-i18n="pill_hiring">Hiring</button>
        <button class="fb-pill" onclick="setCategory('Service',this)" data-i18n="pill_services">Services</button>
        <button class="fb-pill" id="nearMeBtn" onclick="findNearMe()" data-i18n="pill_near_me" style="color:var(--navy); border-color:var(--navy); font-weight:800;">
          <i class="bi bi-geo-alt"></i> Near Me
        </button>
      </div>
      <div class="fb-sort">
        <i class="bi bi-sort-down-alt"></i>
        <select id="sortSelect" onchange="sortCards()">
          <option value="default" data-i18n="sort_default">Sort</option>
          <option value="price-low" data-i18n="sort_low">Low Cost</option>
          <option value="price-high" data-i18n="sort_high">Highest</option>
        </select>
      </div>
    </div>
  </div>
</div>

<div class="lp-section">
  <div class="container">
    <div class="lp-grid-header">
      <span class="lp-grid-title" data-i18n="grid_title">Database Listings</span>
    </div>

    <div class="lp-grid" id="listingGrid">
      <% for(let listing of allListings) { %>
      <div class="listing-item"
           data-category="<%= listing.category %>"
           data-price="<%= listing.price %>"
           data-title="<%= listing.title.toLowerCase() %>"
           data-location="<%= listing.location.toLowerCase() %>">

        <div class="lp-card">
          <div class="lp-thumb">
            <div class="lp-badges">
              <span class="lp-type"><%= listing.type %></span>
              <span class="lp-stars">
                <i class="bi bi-star-fill"></i>
                <%= (listing.reviews.length > 0) ? (listing.reviews.reduce((acc,r)=>acc+r.rating,0)/listing.reviews.length).toFixed(1) : "5.0" %>
              </span>
            </div>
            <% if(listing.imageUrl && listing.imageUrl.url) { %>
              <img src="<%= listing.imageUrl.url %>" alt="Assignment">
            <% } else { %>
              <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=800&q=80" alt="Work">
            <% } %>
            <div class="lp-provider-chip">
              <div class="lp-prov-av"><%= listing.providerName.charAt(0).toUpperCase() %></div>
              <span class="lp-prov-name"><%= listing.providerName.split(' ')[0] %></span>
            </div>
          </div>

          <div class="lp-body">
            <% 
              let statusClass = 'available';
              if (listing.status === 'Closed' || listing.status === 'Booked') statusClass = 'booked';
            %>
            <div class="lp-status <%= statusClass %>" data-status="<%= (listing.status || '').toLowerCase() %>">
              <span class="lp-dot"></span>
              <span class="status-text"><%= listing.status %></span>
            </div>
            <h5 class="lp-title"><%= listing.title %></h5>
            <div class="lp-meta">
              <span class="lp-loc"><i class="bi bi-geo-alt-fill"></i> <%= listing.location %></span>
              <span><span data-i18n="by_label">By</span> <b><%= listing.providerName.split(' ')[0] %></b></span>
            </div>
          </div>

          <div class="lp-footer">
            <div class="lp-price">
              <span class="lp-price-val">₹<%= (listing.price) ? listing.price.toLocaleString("en-IN") : "0" %></span>
              <span class="lp-price-unit"><span data-i18n="per_label">Per</span> <%= listing.priceUnit || "Day" %></span>
            </div>
            <a href="/home/listings/<%= listing._id %>" class="lp-cta">
              <i class="bi bi-arrow-right-short fs-5"></i>
            </a>
          </div>
        </div>
      </div>
      <% } %>

      <div id="noResults" class="d-none">
        <div class="nr-icon">🔍</div>
        <h5 data-i18n="no_results_title">No listings found</h5>
        <p data-i18n="no_results_sub">Try a different search or category</p>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════
     ALL ORIGINAL JS — COMPLETELY UNCHANGED
══════════════════════════════════════════════ -->
<script>
    let currentCategory = 'All';

    function filterCards() {
        const query = document.getElementById('searchInput').value.toLowerCase();
        const items = document.querySelectorAll('.listing-item');
        let count = 0;

        items.forEach(item => {
            const title    = item.getAttribute('data-title');
            const location = item.getAttribute('data-location');
            const category = item.getAttribute('data-category');

            const matchesSearch   = title.includes(query) || location.includes(query);
            const matchesCategory = (currentCategory === 'All' || category === currentCategory);

            if (matchesSearch && matchesCategory) {
                item.style.display = 'block';
                count++;
            } else {
                item.style.display = 'none';
            }
        });
        document.getElementById('noResults')?.classList.toggle('d-none', count > 0);
    }

    function setCategory(cat, btn) {
        currentCategory = cat;
        document.querySelectorAll('.fb-pill').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        filterCards();
    }

    function sortCards() {
        const grid  = document.getElementById('listingGrid');
        const items = Array.from(document.querySelectorAll('.listing-item'));
        const mode  = document.getElementById('sortSelect').value;

        if (mode === 'price-low') {
            items.sort((a,b) => +a.dataset.price - +b.dataset.price);
        } else if (mode === 'price-high') {
            items.sort((a,b) => +b.dataset.price - +a.dataset.price);
        }

        const noRes = document.getElementById('noResults');
        items.forEach(el => grid.insertBefore(el, noRes));
    }

    // Geolocation Feature
    function findNearMe() {
        const btn = document.getElementById('nearMeBtn');
        if (btn.classList.contains('active-geo')) {
            // If already active, clear URL params and reload
            window.location.href = '/home/listings';
            return;
        }

        if (navigator.geolocation) {
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
            navigator.geolocation.getCurrentPosition(
                (position) => {
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;
                    window.location.href = `/home/listings?lat=${lat}&lng=${lng}`;
                },
                (error) => {
                    console.error("Geolocation error:", error);
                    alert("Unable to retrieve your location. Please check browser permissions.");
                    btn.innerHTML = '<i class="bi bi-geo-alt"></i> Near Me';
                }
            );
        } else {
            alert("Geolocation is not supported by your browser.");
        }
    }

    // Set active state on load if lat/lng are in the URL
    document.addEventListener("DOMContentLoaded", () => {
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('lat') && urlParams.has('lng')) {
            const btn = document.getElementById('nearMeBtn');
            btn.classList.add('active-geo');
            btn.style.backgroundColor = 'var(--navy)';
            btn.style.color = '#fff';
            btn.innerHTML = '<i class="bi bi-geo-alt-fill"></i> Nearby Active <i class="bi bi-x ms-1" title="Clear Filter"></i>';
        }
    });
</script>

