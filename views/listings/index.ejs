<!-- ── LANGUAGE SWITCHER STYLES (added only) ── -->
<style>
.r {
  position: fixed;
  top: 70px;
  right: 24px;
  z-index: 9999;
}
.lang-trigger {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 8px 16px;
  background: #1e3a5f;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-family: 'Inter', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  cursor: pointer;
  box-shadow: 0 4px 16px rgba(30,58,95,0.28);
  transition: background 0.2s;
  letter-spacing: 0.2px;
}
.lang-trigger:hover { background: #152d4a; }
.lang-trigger i { font-size: 0.88rem; }
.lang-chevron {
  font-size: 0.6rem !important;
  transition: transform 0.22s ease;
}
.lang-chevron.open { transform: rotate(180deg); }
.lang-dropdown {
  display: none;
  flex-direction: column;
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  background: #fff;
  border: 1px solid #e8e4dc;
  border-radius: 12px;
  padding: 6px;
  min-width: 158px;
  box-shadow: 0 12px 36px rgba(0,0,0,0.11);
  animation: langDrop 0.18s ease;
}
.lang-dropdown.open { display: flex; }
@keyframes langDrop {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}
.lang-option {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 9px 12px;
  border: none;
  border-radius: 8px;
  background: transparent;
  font-family: 'Inter', sans-serif;
  font-size: 0.84rem;
  font-weight: 500;
  color: #7a7169;
  cursor: pointer;
  text-align: left;
  transition: background 0.14s, color 0.14s;
}
.lang-option:hover { background: #f5f3ef; color: #1a1714; }
.lang-option.active { color: #1e3a5f; font-weight: 700; }
.lang-option.active .lang-dot { background: #d97706; }
.lang-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #e8e4dc;
  flex-shrink: 0;
  transition: background 0.2s;
}
/* fade during language switch */
.lp-hero, .fb-wrap, .lp-section {
  transition: opacity 0.16s ease;
}
.lang-fading .lp-hero,
.lang-fading .fb-wrap,
.lang-fading .lp-section { opacity: 0; }
</style>

<!-- ── LANGUAGE SWITCHER BUTTON ── -->
<div class="r">
  <button class="lang-trigger" id="langTrigger" onclick="toggleLangMenu()">
    <i class="bi bi-translate"></i>
    <span id="langLabel">EN</span>
    <i class="bi bi-chevron-down lang-chevron" id="langChevron"></i>
  </button>
  <div class="lang-dropdown" id="langDropdown">
    <button class="lang-option active" data-lang="en" onclick="setLanguage('en')"><span class="lang-dot"></span>English</button>
    <button class="lang-option"        data-lang="hi" onclick="setLanguage('hi')"><span class="lang-dot"></span>हिंदी</button>
    <button class="lang-option"        data-lang="mr" onclick="setLanguage('mr')"><span class="lang-dot"></span>मराठी</button>
    <button class="lang-option"        data-lang="kn" onclick="setLanguage('kn')"><span class="lang-dot"></span>ಕನ್ನಡ</button>
    <button class="lang-option"        data-lang="ta" onclick="setLanguage('ta')"><span class="lang-dot"></span>தமிழ்</button>
  </div>
</div>

