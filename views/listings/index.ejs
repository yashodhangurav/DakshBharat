<style>
:root {
  --bg:         #f5f3ef;
  --surface:    #ffffff;
  --ink:        #1a1714;
  --muted:      #7a7169;
  --border:     #e8e4dc;
  --amber:      #d97706;
  --amber-lt:   #fef3c7;
  --amber-glow: rgba(217,119,6,.18);
  --navy:       #1e3a5f;
  --navy-lt:    #e8edf4;
  --green:      #059669;
  --red:        #dc2626;
  --ease:       cubic-bezier(0.4,0,0.2,1);
  --spring:     cubic-bezier(0.34,1.56,0.64,1);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

body{
  background:var(--bg);
  color:var(--ink);
  font-family:'Inter',system-ui,sans-serif;
  -webkit-font-smoothing:antialiased;
}

.lp-hero {
  padding: 35px 0 25px;
  position: relative;
  overflow: hidden;
  text-align: center;
}

.lp-hero-bg {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: clamp(60px, 12vw, 130px);
  font-weight: 900;
  letter-spacing: -.06em;
  color: rgba(28, 25, 23, 0.03);
  white-space: nowrap;
  pointer-events: none;
  user-select: none;
  line-height: 1;
}

.lp-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: .62rem; font-weight: 700; letter-spacing: 3px;
  text-transform: uppercase; color: var(--muted);
  margin-bottom: 10px;
}
.lp-eyebrow-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--amber);
  animation: lp-blink 2s ease infinite;
}
@keyframes lp-blink {
  0%, 100% { opacity: 1; } 50% { opacity: .3; }
}

.lp-hero h1 {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 800; letter-spacing: -.05em;
  color: var(--ink); line-height: 1.1;
  margin-bottom: 8px;
}
.lp-hero h1 .hi {
  position: relative; display: inline-block;
  color: var(--amber);
}
.lp-hero h1 .hi::after {
  content: '';
  position: absolute; bottom: -2px; left: 0; right: 0; height: 3px;
  background: var(--amber); border-radius: 3px;
  transform: scaleX(0); transform-origin: left;
  animation: lp-underline .7s .4s var(--ease) forwards;
}
@keyframes lp-underline { to { transform: scaleX(1); } }

.lp-hero p {
  font-size: .88rem; color: var(--muted);
  max-width: 440px; margin: 0 auto; line-height: 1.5;
}

.lp-chips {
  display: flex; align-items: center; justify-content: center;
  gap: 8px; margin-top: 18px; flex-wrap: wrap;
}
.lp-chip {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 100px;
  padding: 5px 14px;
  font-size: .7rem; font-weight: 700; color: var(--muted);
}
.lp-chip i { font-size: .75rem; color: var(--amber); }

.fb-wrap{
  position:sticky;top:64px;z-index:100;
  padding:10px 0;
  background:rgba(245,243,239,.94);
  backdrop-filter:blur(20px);
  -webkit-backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
}
.fb-inner{ display:flex;align-items:center;gap:8px; }
.fb-search{ flex:1;min-width:160px; display:flex;align-items:center;gap:8px; background:var(--surface); border:1.5px solid var(--border); border-radius:12px; padding:0 14px;height:42px; transition:border-color .2s,box-shadow .2s; }
.fb-search:focus-within{ border-color:var(--amber); box-shadow:0 0 0 4px var(--amber-glow); }
.fb-search input{ border:none;outline:none;background:transparent; font-size:.84rem;font-weight:500;color:var(--ink);width:100%; font-family:inherit; }
.fb-pills{ display:flex;align-items:center;gap:4px; background:var(--surface); border:1.5px solid var(--border); border-radius:12px;padding:4px; }
.fb-pill{ font-size:.78rem;font-weight:700; color:var(--muted); padding:7px 16px;border-radius:9px; border:none;background:none;cursor:pointer; transition:all .18s; white-space:nowrap;font-family:inherit; }
.fb-pill.active{background:var(--navy);color:#fff;}
.fb-sort{ display:flex;align-items:center;gap:7px; background:var(--surface); border:1.5px solid var(--border); border-radius:12px; padding:0 14px;height:42px; }
.fb-sort select{ border:none;outline:none;background:transparent; font-size:.82rem;font-weight:700;color:var(--ink); cursor:pointer;appearance:none;font-family:inherit; }

.lp-section{padding:24px 0 100px;}
.lp-grid-header{ display:flex;align-items:center;justify-content:space-between; margin-bottom:20px; }
.lp-grid-title{ font-size:.72rem;font-weight:700; letter-spacing:2px;text-transform:uppercase;color:var(--muted); }
.lp-grid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(290px,1fr)); gap:22px; }

.lp-card{ background:var(--surface); border:1.5px solid var(--border); border-radius:20px; overflow:hidden; display:flex;flex-direction:column; position:relative; cursor:pointer; transition: transform .35s var(--spring), box-shadow .35s var(--ease), border-color .25s var(--ease); }
.lp-card:hover{ transform:translateY(-8px); box-shadow: 0 12px 32px -4px rgba(28,25,23,.1); border-color:var(--amber); }
.lp-thumb{ position:relative;height:200px;overflow:hidden; background:var(--navy-lt); flex-shrink:0; }
.lp-thumb img{ width:100%;height:100%;object-fit:cover; display:block; transition:transform .6s var(--ease); }
.lp-card:hover .lp-thumb img{transform:scale(1.08);}
.lp-thumb::after{ content:''; position:absolute;inset:0; background:linear-gradient(to top,rgba(26,23,20,.55) 0%,transparent 45%); pointer-events:none; }
.lp-badges{ position:absolute;top:13px;left:13px;right:13px; display:flex;justify-content:space-between;align-items:flex-start; z-index:3; }
.lp-type{ font-size:.6rem;font-weight:800; letter-spacing:1px;text-transform:uppercase; padding:5px 12px;border-radius:8px; background:var(--navy);color:#fff; backdrop-filter:blur(8px); box-shadow:0 2px 8px rgba(30,58,95,.35); }
.lp-stars{ display:inline-flex;align-items:center;gap:5px; background:rgba(255,255,255,.95); font-size:.7rem;font-weight:800; padding:5px 10px;border-radius:8px; color:var(--ink); }
.lp-provider-chip{ position:absolute;bottom:12px;left:13px; z-index:3; display:inline-flex;align-items:center;gap:6px; background:rgba(255,255,255,.12); backdrop-filter:blur(10px); border:1px solid rgba(255,255,255,.2); border-radius:100px; padding:4px 11px 4px 4px; }
.lp-prov-av{ width:22px;height:22px;border-radius:50%; background:var(--amber); display:flex;align-items:center;justify-content:center; font-size:.6rem;font-weight:800;color:#fff; }
.lp-prov-name{ font-size:.65rem;font-weight:700;color:rgba(255,255,255,.9); }
.lp-body{ padding:18px 18px 14px; flex-grow:1; position:relative;z-index:1; }
.lp-status{ display:inline-flex;align-items:center;gap:5px; font-size:.6rem;font-weight:800; text-transform:uppercase;margin-bottom:9px; }
.lp-status.available{color:var(--green);}
.lp-status.booked{color:var(--red);}
.lp-dot{ width:6px;height:6px;border-radius:50%;flex-shrink:0; background:currentColor; }
.lp-title{ font-size:1rem;font-weight:700; color:var(--ink); line-height:1.35; display:-webkit-box; -webkit-line-clamp:2;-webkit-box-orient:vertical; overflow:hidden; min-height:2.7rem; margin-bottom:13px; }
.lp-meta{ display:flex;justify-content:space-between;align-items:center; font-size:.75rem;color:var(--muted); }
.lp-loc{display:flex;align-items:center;gap:4px;}
.lp-footer{ padding:13px 18px; border-top:1.5px solid var(--border); display:flex;justify-content:space-between;align-items:center; background:rgba(245,243,239,.6); }
.lp-price-val{ font-size:1.3rem;font-weight:900; color:var(--ink); letter-spacing:-.04em; }
.lp-cta{ width:40px;height:40px; background:var(--navy);color:#fff; border-radius:12px; display:inline-flex;align-items:center;justify-content:center; text-decoration:none; transition: all .25s; }
.lp-cta:hover{ transform:scale(1.1) rotate(-5deg); background:var(--amber); color:#fff; }

@keyframes lp-fadeup{ from{opacity:0;transform:translateY(20px);} to{opacity:1;transform:translateY(0);} }
.listing-item{ animation:lp-fadeup .45s var(--ease) both; }

@media(max-width:768px){ .lp-grid{grid-template-columns:1fr 1fr;gap:14px;} .lp-thumb{height:155px;} }
@media(max-width:480px){ .lp-grid{grid-template-columns:1fr;} }

