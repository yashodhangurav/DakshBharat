// ── Dropdown toggle ──────────────────────────────
function toggleLangMenu() {
  const dd = document.getElementById('langDropdown');
  const ch = document.getElementById('langChevron');
  const open = dd.classList.toggle('open');
  ch.classList.toggle('open', open);
}
document.addEventListener('click', e => {
  if (!e.target.closest('.r')) {
    document.getElementById('langDropdown').classList.remove('open');
    document.getElementById('langChevron').classList.remove('open');
  }
});

// ── Core switcher ────────────────────────────────
function setLanguage(lang) {
  const t = i18n[lang];
  if (!t) return;

  document.body.classList.add('lang-fading');

  setTimeout(() => {
    // text elements
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (t[key] !== undefined) el.textContent = t[key];
    });

    // placeholder attributes
    document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
      const key = el.getAttribute('data-i18n-placeholder');
      if (t[key] !== undefined) el.setAttribute('placeholder', t[key]);
    });

    // select <option> elements
    document.querySelectorAll('option[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (t[key] !== undefined) el.textContent = t[key];
    });

    // status texts inside cards (Available/Booked/Open/Closed)
    document.querySelectorAll('.lp-status').forEach(el => {
      const spanEl = el.querySelector('.status-text');
      let statusKey = el.dataset.status;
      if (statusKey && spanEl && t['status_' + statusKey]) {
        spanEl.textContent = t['status_' + statusKey];
      }
    });

    // trigger label
    document.getElementById('langLabel').textContent = t.langLabel;

    // active state on options
    document.querySelectorAll('.lang-option').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.lang === lang);
    });

    // persist
    try { localStorage.setItem('sb_lang', lang); } catch(e) {}

    document.body.classList.remove('lang-fading');
  }, 160);

  // close dropdown
  document.getElementById('langDropdown').classList.remove('open');
  document.getElementById('langChevron').classList.remove('open');
}

// ── Restore on load ──────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  // Inject Near Me translations dynamically so we don't need to rebuild the whole language map
  i18n.en.pill_near_me = 'Near Me';
  i18n.hi.pill_near_me = 'मेरे आस-पास';
  i18n.mr.pill_near_me = 'माझ्या जवळ';
  i18n.kn.pill_near_me = 'ನನ್ನ ಹತ್ತಿರ';
  i18n.ta.pill_near_me = 'என் அருகில்';

  let saved = 'en';
  try { saved = localStorage.getItem('sb_lang') || 'en'; } catch(e) {}
  if (saved !== 'en') setLanguage(saved);
  else setLanguage('en'); // Force UI to update with new injected keys
});
</script>
