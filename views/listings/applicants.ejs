<% layout("/layouts/boilerplate.ejs") %>

<div class="container mt-5 mb-5">
    <a href="/home/listings/<%= listing._id %>" class="text-decoration-none text-muted mb-4 d-inline-block fw-bold">
      <i class="bi bi-arrow-left"></i> Back to Listing
    </a>
    <h2 class="fw-bold mb-4">Applicants for <%= listing.title %></h2>

    <% if (listing.applicants && listing.applicants.length > 0) { %>
        <div class="table-responsive bg-white rounded-4 shadow-sm border p-3">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Candidate Name</th>
                        <th scope="col">Applied On</th>
                        <th scope="col">Resume / Portfolio</th>
                        <th scope="col">Status</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% listing.applicants.forEach(app => { %>
                        <tr>
                            <td class="fw-bold"><%= app.user.username %></td>
                            <td><%= new Date(app.appliedAt).toLocaleDateString() %></td>
                            <td>
                                <a href="<%= app.resumeLink %>" target="_blank" class="btn btn-sm btn-outline-primary mb-1" title="View in Browser"><i class="bi bi-eye"></i></a>
                                <a href="/home/listings/<%= listing._id %>/applicants/<%= app.user._id %>/download-resume" class="btn btn-sm btn-outline-success mb-1 ms-1" title="Download File"><i class="bi bi-download"></i> Download File</a>
                            </td>
                            <td>
                                <% if(app.status === 'Pending') { %>
                                    <span class="badge bg-warning text-dark"><%= app.status %></span>
                                <% } else if (app.status === 'Accepted') { %>
                                    <span class="badge bg-success"><%= app.status %></span>
                                <% } else { %>
                                    <span class="badge bg-danger"><%= app.status %></span>
                                <% } %>
                            </td>
                            <td class="text-end">
                                <% if(app.status === 'Pending') { %>
                                    <form action="/home/listings/<%= listing._id %>/applicants/<%= app.user._id %>/Accepted" method="POST" class="d-inline">
                                        <button class="btn btn-sm btn-success fw-bold px-3"><i class="bi bi-check-circle"></i> Accept</button>
                                    </form>
                                    <form action="/home/listings/<%= listing._id %>/applicants/<%= app.user._id %>/Rejected" method="POST" class="d-inline">
                                        <button class="btn btn-sm btn-outline-danger px-3 ms-2"><i class="bi bi-x-circle"></i> Reject</button>
                                    </form>
                                <% } else { %>
                                    <span class="text-muted small">Processed</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="text-center py-5 bg-white border rounded-4 shadow-sm">
            <h4 class="text-muted">No applicants yet.</h4>
            <p class="text-muted">Check back later once candidates start applying.</p>
        </div>
    <% } %>
</div>
