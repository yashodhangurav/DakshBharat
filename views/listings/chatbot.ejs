<% layout("/layouts/boilerplate.ejs") %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>
    :root {
        --nx-bg: #f8fafc;
        --nx-surface: #ffffff;
        --nx-ink: #0f172a;
        --nx-muted: #64748b;
        --nx-border: rgba(15, 23, 42, 0.08);
        --nx-amber: #d97706;
        --nx-navy: #0f172a;
        --nx-ease: cubic-bezier(0.4, 0, 0.2, 1);
    }

    body {
        background-color: #f1f5f9;
        font-family: 'Inter', sans-serif;
        margin: 0;
        padding: 0;
    }

    /* ── MAIN CONTAINER ── */
    .chatbot-main-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: calc(100vh - 80px);
        padding: 20px;
    }

    .chatbot-container {
        width: 100%;
        max-width: 500px;
        height: 750px;
        background: var(--nx-surface);
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border: 1px solid var(--nx-border);
    }

    /* ── HEADER ── */
    .chatbot-header {
        background: var(--nx-navy);
        color: white;
        padding: 24px;
        position: relative;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    /* 3D LOGO MINI VERSION */
    .mini-logo-box {
        width: 36px; height: 36px;
        perspective: 1000px;
    }
    .nx-cube {
        width: 100%; height: 100%;
        position: relative;
        transform-style: preserve-3d;
        animation: nx-spin 8s infinite linear;
    }
    .nx-face {
        position: absolute; width: 100%; height: 100%;
        border: 1.5px solid var(--nx-amber);
        background: var(--nx-navy);
        display: flex; align-items: center; justify-content: center;
        font-weight: 900; font-size: 0.8rem; color: white;
    }
    .nx-front  { transform: translateZ(18px); }
    .nx-back   { transform: rotateY(180deg) translateZ(18px); }
    .nx-right-f { transform: rotateY(90deg) translateZ(18px); background: var(--nx-amber); }
    .nx-left-f  { transform: rotateY(-90deg) translateZ(18px); }
    .nx-top    { transform: rotateX(90deg) translateZ(18px); }
    .nx-bottom { transform: rotateX(-90deg) translateZ(18px); background: var(--nx-amber); }
    
    @keyframes nx-spin { to { transform: rotateX(360deg) rotateY(360deg); } }

    .chatbot-header h1 {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 1.25rem;
        font-weight: 800;
        margin: 0;
    }
    .chatbot-header p {
        font-size: 0.75rem;
        opacity: 0.7;
        margin: 2px 0 0;
    }

    /* ── MESSAGES ── */
    .chat-messages {
        flex: 1;
        padding: 24px;
        overflow-y: auto;
        background: #f8fafc;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .message-content {
        padding: 14px 18px;
        border-radius: 18px;
        font-size: 0.9rem;
        line-height: 1.5;
        max-width: 85%;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    .message.bot .message-content {
        background: white;
        color: var(--nx-ink);
        border: 1px solid var(--nx-border);
        border-bottom-left-radius: 4px;
    }

    .message.user { align-self: flex-end; }
    .message.user .message-content {
        background: var(--nx-navy);
        color: white;
        border-bottom-right-radius: 4px;
    }

    /* ── INPUT AREA ── */
    .chat-input-container {
        padding: 24px;
        background: white;
        border-top: 1px solid var(--nx-border);
    }

    .suggestions, .equipment-category {
        display: flex;
        gap: 8px;
        overflow-x: auto;
        padding-bottom: 12px;
        scrollbar-width: none;
    }
    .suggestions::-webkit-scrollbar { display: none; }

    .suggestion-chip, .category-chip {
        white-space: nowrap;
        background: #f1f5f9;
        border: 1px solid var(--nx-border);
        padding: 8px 16px;
        border-radius: 100px;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--nx-muted);
        cursor: pointer;
        transition: all 0.2s;
    }
    .suggestion-chip:hover, .category-chip:hover {
        background: var(--nx-amber);
        color: white;
        border-color: var(--nx-amber);
    }

    .chat-input-wrapper {
        display: flex;
        gap: 12px;
        align-items: center;
        background: #f1f5f9;
        padding: 8px 8px 8px 16px;
        border-radius: 16px;
        border: 1px solid transparent;
        transition: all 0.2s;
    }
    .chat-input-wrapper:focus-within {
        background: white;
        border-color: var(--nx-amber);
        box-shadow: 0 0 0 4px rgba(217, 119, 6, 0.1);
    }

    #chat-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        font-size: 0.9rem;
        resize: none;
        color: var(--nx-ink);
        max-height: 100px;
    }

    #send-button {
        background: var(--nx-navy);
        color: white;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s;
    }
    #send-button:hover {
        background: var(--nx-amber);
        transform: scale(1.05);
    }

    /* ── TYPING ── */
    .typing-indicator {
        display: none;
        background: white;
        padding: 12px 16px;
        border-radius: 18px;
        border: 1px solid var(--nx-border);
        width: fit-content;
    }
    .typing-dots { display: flex; gap: 4px; }
    .typing-dot {
        width: 6px; height: 6px;
        background: var(--nx-muted);
        border-radius: 50%;
        animation: bounce 1.4s infinite ease-in-out;
    }
    @keyframes bounce { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }
</style>

<div class="chatbot-main-container">
    <div class="chatbot-container">
        <div class="chatbot-header">
            <div class="mini-logo-box">
                <div class="nx-cube">
                    <div class="nx-face nx-front"><span>D</span></div>
                    <div class="nx-face nx-back"></div>
                    <div class="nx-face nx-right-f"><span>B</span></div>
                    <div class="nx-face nx-left-f"></div>
                    <div class="nx-face nx-top"></div>
                    <div class="nx-face nx-bottom"></div>
                </div>
            </div>
            <div>
                <h1>Daksh Assistant</h1>
                <p>Powered by DakshBharat AI</p>
            </div>
        </div>
        
        <div class="chat-messages" id="chat-messages"></div>
        
        <div class="chat-input-container">
            <div class="suggestions">
                <div class="suggestion-chip" data-prompt="How do I list my equipment?">List Equipment</div>
                <div class="suggestion-chip" data-prompt="What equipment is available?">Find Equipment</div>
                <div class="suggestion-chip" data-prompt="How does payment work?">Payment Info</div>
            </div>
            
            <div class="equipment-category">
                <div class="category-chip" data-prompt="Tell me about tractor rentals">Tractors</div>
                <div class="category-chip" data-prompt="What harvesting equipment is available?">Harvesting</div>
                <div class="category-chip" data-prompt="Show me irrigation equipment">Irrigation</div>
            </div>
            
            <div class="chat-input-wrapper">
                <textarea id="chat-input" placeholder="Ask about equipment or services..." rows="1"></textarea>
                <button id="send-button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    class DakshChatbot {
        constructor() {
            this.chatMessages = document.getElementById('chat-messages');
            this.chatInput = document.getElementById('chat-input');
            this.sendButton = document.getElementById('send-button');
            this.setupEventListeners();
            this.addMessage("Namaste! I'm your Daksh assistant. How can I help you navigate the marketplace today?", 'bot');
        }

        setupEventListeners() {
            this.sendButton.onclick = () => this.handleSend();
            this.chatInput.onkeypress = (e) => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); this.handleSend(); } };
            
            document.querySelectorAll('.suggestion-chip, .category-chip').forEach(chip => {
                chip.onclick = () => {
                    this.chatInput.value = chip.dataset.prompt;
                    this.handleSend();
                };
            });
        }

        async handleSend() {
            const msg = this.chatInput.value.trim();
            if (!msg) return;

            this.addMessage(msg, 'user');
            this.chatInput.value = '';
            
            // Show typing...
            const typing = document.createElement('div');
            typing.className = 'message bot typing-indicator';
            typing.innerHTML = '<div class="typing-dots"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div>';
            typing.style.display = 'block';
            this.chatMessages.appendChild(typing);
            this.chatMessages.scrollTop = this.chatMessages.scrollHeight;

            // Mock Response
            setTimeout(() => {
                typing.remove();
                this.addMessage("I'm analyzing your request for '" + msg + "'. Our marketplace currently has several verified listings matching your query. Would you like to view them?", 'bot');
            }, 1500);
        }

        addMessage(text, sender) {
            const div = document.createElement('div');
            div.className = `message ${sender}`;
            div.innerHTML = `<div class="message-content">${text}</div>`;
            this.chatMessages.appendChild(div);
            this.chatMessages.scrollTop = this.chatMessages.scrollHeight;
        }
    }

    document.addEventListener('DOMContentLoaded', () => new DakshChatbot());
</script>