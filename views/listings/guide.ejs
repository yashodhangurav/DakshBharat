<% layout("/layouts/boilerplate.ejs") %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>
:root {
  --bg:      #f5f3ef;
  --surface: #ffffff;
  --ink:     #1a1714;
  --muted:   #78716c;
  --border:  #e8e4dc;
  --amber:   #d97706;
  --amber-lt:#fef3c7;
  --navy:    #1e3a5f;
  --navy-lt: #e8edf4;
  --spring:  cubic-bezier(0.34,1.56,0.64,1);
  --ease:    cubic-bezier(0.4,0,0.2,1);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{
  background:var(--bg);
  color:var(--ink);
  font-family:'Inter',system-ui,sans-serif;
  -webkit-font-smoothing:antialiased;
}

/* ─── SHARED SECTION HEADER ─── */
.sec-eyebrow{
  display:inline-flex;align-items:center;gap:8px;
  font-size:.68rem;font-weight:700;letter-spacing:3px;
  text-transform:uppercase;color:var(--muted);
  margin-bottom:14px;
}
.sec-eyebrow-bar{
  display:block;width:20px;height:2px;
  background:var(--amber);border-radius:2px;
}
.sec-title{
  font-size:clamp(2rem,4.5vw,3.2rem);
  font-weight:800;letter-spacing:-.05em;
  color:var(--ink);line-height:1.08;
  margin-bottom:14px;
}
.sec-title em{color:var(--amber);font-style:normal;}
.sec-sub{
  font-size:1rem;color:var(--muted);
  max-width:520px;margin:0 auto;line-height:1.65;
}

/* ═══════════════════════════════════════
   HOW IT WORKS
═══════════════════════════════════════ */
.hiw-section{
  padding:80px 0 90px;
  position:relative;overflow:hidden;
}
/* faint big bg text */
.hiw-bg-text{
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);
  font-size:clamp(100px,16vw,220px);
  font-weight:900;letter-spacing:-.06em;
  color:rgba(28,25,23,.025);
  white-space:nowrap;pointer-events:none;
  user-select:none;line-height:1;
}

.hiw-header{text-align:center;margin-bottom:64px;}

/* connecting line */
.hiw-track{
  position:relative;
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:20px;
}
.hiw-track::before{
  content:'';
  position:absolute;
  top:52px;left:calc(12.5% + 10px);right:calc(12.5% + 10px);
  height:1px;
  background:repeating-linear-gradient(
    to right,
    var(--border) 0,var(--border) 8px,
    transparent 8px,transparent 16px
  );
  z-index:0;
}

/* step card */
.hiw-step{
  position:relative;z-index:1;
  display:flex;flex-direction:column;align-items:center;
  text-align:center;
  padding:0 8px;
  animation:fadeup .5s var(--ease) both;
}
.hiw-step:nth-child(1){animation-delay:.05s;}
.hiw-step:nth-child(2){animation-delay:.12s;}
.hiw-step:nth-child(3){animation-delay:.19s;}
.hiw-step:nth-child(4){animation-delay:.26s;}

@keyframes fadeup{
  from{opacity:0;transform:translateY(24px);}
  to{opacity:1;transform:translateY(0);}
}

.hiw-num{
  position:absolute;top:-8px;right:calc(50% - 44px);
  font-size:.6rem;font-weight:900;letter-spacing:1px;
  color:var(--amber);background:var(--amber-lt);
  padding:3px 9px;border-radius:100px;
  border:1px solid rgba(217,119,6,.2);
}

.hiw-icon{
  width:104px;height:104px;
  background:var(--surface);
  border:2px solid var(--border);
  border-radius:28px;
  display:flex;align-items:center;justify-content:center;
  font-size:2rem;color:var(--navy);
  margin-bottom:22px;
  transition:
    background .3s var(--ease),
    border-color .3s,
    transform .35s var(--spring),
    box-shadow .3s var(--ease),
    color .3s;
  position:relative;
}
.hiw-step:hover .hiw-icon{
  background:var(--navy);
  border-color:var(--navy);
  color:#fff;
  transform:translateY(-8px) scale(1.06);
  box-shadow:0 14px 32px rgba(30,58,95,.22);
}

.hiw-step-title{
  font-size:.98rem;font-weight:800;
  letter-spacing:-.02em;color:var(--ink);
  margin-bottom:8px;
}
.hiw-step-body{
  font-size:.84rem;color:var(--muted);
  line-height:1.6;max-width:200px;
}

/* CTA row */
.hiw-cta{
  text-align:center;margin-top:60px;
}
.btn-main{
  display:inline-flex;align-items:center;gap:10px;
  background:var(--navy);color:#fff;
  padding:15px 36px;
  border-radius:12px;
  font-size:.9rem;font-weight:700;
  text-decoration:none;letter-spacing:-.01em;
  position:relative;overflow:hidden;
  transition:transform .25s var(--spring),box-shadow .25s var(--ease);
}
.btn-main::before{
  content:'';
  position:absolute;inset:0;border-radius:12px;
  background:var(--amber);
  transform:translateY(100%);
  transition:transform .3s var(--ease);
}
.btn-main span,.btn-main i{position:relative;z-index:1;}
.btn-main:hover{
  transform:translateY(-3px);
  box-shadow:0 10px 28px rgba(217,119,6,.3);
  color:#fff;
}
.btn-main:hover::before{transform:translateY(0);}
.btn-main:active{transform:scale(.96);}

/* ═══════════════════════════════════════
   TEAM SECTION
═══════════════════════════════════════ */
.team-section{
  padding:80px 0 100px;
  background:var(--surface);
  border-top:1px solid var(--border);
}
.team-header{text-align:center;margin-bottom:60px;}

.team-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:20px;
}

.team-card{
  background:var(--bg);
  border:1.5px solid var(--border);
  border-radius:20px;
  padding:32px 24px 28px;
  display:flex;flex-direction:column;align-items:center;
  text-align:center;
  transition:
    transform .35s var(--spring),
    box-shadow .3s var(--ease),
    border-color .25s;
  position:relative;overflow:hidden;
}
/* corner accent */
.team-card::before{
  content:'';
  position:absolute;top:0;right:0;
  width:60px;height:60px;
  background:linear-gradient(135deg,var(--amber-lt),transparent);
  border-bottom-left-radius:60px;
  opacity:0;
  transition:opacity .3s;
}
.team-card:hover{
  transform:translateY(-8px);
  box-shadow:0 18px 44px -6px rgba(28,25,23,.11);
  border-color:var(--amber);
}
.team-card:hover::before{opacity:1;}

/* avatar */
.team-avatar{
  width:80px;height:80px;
  border-radius:24px;
  display:flex;align-items:center;justify-content:center;
  font-size:1.6rem;font-weight:900;
  color:#fff;
  margin-bottom:18px;
  position:relative;
  flex-shrink:0;
  transition:transform .35s var(--spring);
}
.team-card:hover .team-avatar{transform:scale(1.08) rotate(-4deg);}

/* unique color per card */
.team-card:nth-child(1) .team-avatar{background:var(--navy);}
.team-card:nth-child(2) .team-avatar{background:#0e7490;}
.team-card:nth-child(3) .team-avatar{background:var(--amber);}
.team-card:nth-child(4) .team-avatar{background:#7c3aed;}

/* avatar inner border ring */
.team-avatar::after{
  content:'';
  position:absolute;inset:-3px;
  border-radius:27px;
  border:2px solid rgba(217,119,6,.2);
  opacity:0;
  transition:opacity .25s;
}
.team-card:hover .team-avatar::after{opacity:1;}

.team-initial{line-height:1;}

.team-name{
  font-size:1rem;font-weight:800;
  letter-spacing:-.025em;color:var(--ink);
  margin-bottom:5px;
}
.team-role{
  font-size:.72rem;font-weight:600;
  color:var(--muted);letter-spacing:.3px;
  margin-bottom:14px;
}
.team-tag{
  display:inline-flex;align-items:center;gap:5px;
  font-size:.65rem;font-weight:700;letter-spacing:.5px;
  text-transform:uppercase;
  color:var(--navy);
  background:var(--navy-lt);
  padding:4px 12px;border-radius:100px;
  border:1px solid rgba(30,58,95,.12);
}

/* built-by banner */
.built-banner{
  margin-top:52px;
  text-align:center;
}
.built-banner p{
  font-size:.78rem;font-weight:600;
  color:var(--muted);letter-spacing:.5px;
  display:inline-flex;align-items:center;gap:10px;
}
.built-banner p::before,
.built-banner p::after{
  content:'';display:block;
  width:40px;height:1px;background:var(--border);
}

/* ─── RESPONSIVE ─── */
@media(max-width:991px){
  .hiw-track{grid-template-columns:1fr 1fr;gap:24px;}
  .hiw-track::before{display:none;}
  .team-grid{grid-template-columns:1fr 1fr;gap:16px;}
}
@media(max-width:540px){
  .hiw-track{grid-template-columns:1fr;}
  .team-grid{grid-template-columns:1fr 1fr;gap:12px;}
  .team-card{padding:24px 16px 20px;}
  .team-avatar{width:64px;height:64px;font-size:1.3rem;border-radius:18px;}
}
</style>

