
<% layout("/layouts/boilerplate.ejs") %>

<!-- ── Language Switcher ── -->
<div class="lang-bar">
  <button class="lang-trigger" id="langTrigger" onclick="toggleLangMenu()">
    <i class="bi bi-translate"></i>
    <span id="langLabel">EN</span>
    <i class="bi bi-chevron-down lang-chevron" id="langChevron"></i>
  </button>
  <div class="lang-dropdown" id="langDropdown">
    <button class="lang-option active" data-lang="en"   onclick="setLanguage('en')">  <span class="lang-dot"></span> English   </button>
    <button class="lang-option"        data-lang="hi"   onclick="setLanguage('hi')">  <span class="lang-dot"></span> हिंदी      </button>
    <button class="lang-option"        data-lang="mr"   onclick="setLanguage('mr')">  <span class="lang-dot"></span> मराठी      </button>
    <button class="lang-option"        data-lang="kn"   onclick="setLanguage('kn')">  <span class="lang-dot"></span> ಕನ್ನಡ      </button>
    <button class="lang-option"        data-lang="ta"   onclick="setLanguage('ta')">  <span class="lang-dot"></span> தமிழ்      </button>
  </div>
</div>

<div class="kw-wrap">

  <!-- ===== HERO ===== -->
  <section class="kw-hero">
    <div class="kw-hero-inner">

      <div class="kw-hero-left" data-aos="fade-up">
        <div class="kw-badge">
          <i class="bi bi-patch-check-fill"></i>
          <span data-i18n="badge">India's Verified Skill Network</span>
        </div>

        <h1 class="kw-heading">
          <span data-i18n="h1_1">Building the</span> <span class="kw-accent" data-i18n="h1_2">Future</span><br>
          <span data-i18n="h1_3">with Local Expertise.</span>
        </h1>

        <p class="kw-subtext">
          <span data-i18n="subtext_1">The unified ecosystem connecting</span>
          <strong data-i18n="subtext_companies">Companies</strong>,
          <strong data-i18n="subtext_employees">Skilled Employees</strong>,
          <span data-i18n="subtext_and">and</span>
          <strong data-i18n="subtext_owners">Project Owners</strong>
          <span data-i18n="subtext_2">in one digital gallery of trust.</span>
        </p>

        <div class="kw-cta-row">
          <a href="/home/listings" class="kw-btn-primary" data-i18n="btn_explore">Explore Marketplace</a>
          <a href="/signup" class="kw-btn-text">
            <span data-i18n="btn_join">Join the Network</span> <i class="bi bi-arrow-right"></i>
          </a>
        </div>

        <div class="kw-stats-row">
          <div class="kw-stat">
            <strong>12K+</strong>
            <span data-i18n="stat_workers">Skilled Workers</span>
          </div>
          <div class="kw-stat-sep"></div>
          <div class="kw-stat">
            <strong>800+</strong>
            <span data-i18n="stat_companies">Companies</span>
          </div>
          <div class="kw-stat-sep"></div>
          <div class="kw-stat">
            <strong>98%</strong>
            <span data-i18n="stat_satisfaction">Satisfaction</span>
          </div>
        </div>
      </div>

      <div class="kw-hero-right" data-aos="fade-up" data-aos-delay="150">
        <div class="kw-card kw-card-main">
          <div class="kw-card-eyebrow" data-i18n="card_eyebrow">Our Philosophy</div>
          <div class="kw-card-icon"><i class="bi bi-shield-shaded"></i></div>
          <h3><span data-i18n="card_h3_1">A Heritage of</span><br><span data-i18n="card_h3_2">Digital Trust</span></h3>
          <p data-i18n="card_p">We've replaced fragmented portals with a single, elegant gallery where every skill is a masterpiece and every hire is secure.</p>
          <div class="kw-verified-badge">
            <i class="bi bi-check-circle-fill"></i>
            <span data-i18n="verified">Verified Enterprise</span>
          </div>
        </div>

        <div class="kw-mini-row">
          <div class="kw-card kw-card-mini kw-card-live">
            <div class="kw-pulse"></div>
            <span data-i18n="live_portfolio">Live Portfolio</span>
            <i class="bi bi-person-badge"></i>
          </div>
          <div class="kw-card kw-card-mini kw-card-experts">
            <div class="kw-avatars">
              <img src="https://ui-avatars.com/api/?name=JS&background=c2410c&color=fff&bold=true" alt="JS">
              <img src="https://ui-avatars.com/api/?name=RK&background=1e3a5f&color=fff&bold=true" alt="RK">
              <img src="https://ui-avatars.com/api/?name=MA&background=0e7490&color=fff&bold=true" alt="MA">
            </div>
            <span data-i18n="verified_experts">Verified Experts</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="kw-services">
    <div class="kw-services-inner">

      <div class="kw-services-grid">

        <div class="kw-svc kw-svc-dark" data-aos="fade-up">
          <div class="kw-svc-top">
            <div class="kw-svc-num">01</div>
            <div class="kw-svc-ico"><i class="bi bi-building"></i></div>
          </div>
          <h3 data-i18n="svc1_h3">For Companies</h3>
          <p data-i18n="svc1_p">Source verified talent and manage industrial scale recruitment with ease. From SMEs to large enterprises.</p>
          <div class="kw-svc-foot">
            <span class="kw-tag" data-i18n="verified">Verified Enterprise</span>
            <span class="kw-arrow"><i class="bi bi-arrow-up-right"></i></span>
          </div>
        </div>

        <div class="kw-svc kw-svc-amber" data-aos="fade-up" data-aos-delay="100">
          <div class="kw-svc-top">
            <div class="kw-svc-num">02</div>
            <div class="kw-svc-ico"><i class="bi bi-person-badge"></i></div>
          </div>
          <h3 data-i18n="svc2_h3">Digital Identity</h3>
          <p data-i18n="svc2_p">Turn your manual skills into a verifiable, high-visibility digital record. Your expertise, amplified.</p>
          <div class="kw-svc-foot">
            <span class="kw-tag" data-i18n="live_portfolio">Live Portfolio</span>
            <span class="kw-arrow"><i class="bi bi-arrow-up-right"></i></span>
          </div>
        </div>

        <div class="kw-svc kw-svc-light" data-aos="fade-up" data-aos-delay="200">
          <div class="kw-svc-top">
            <div class="kw-svc-num">03</div>
            <div class="kw-svc-ico"><i class="bi bi-stars"></i></div>
          </div>
          <h3 data-i18n="svc3_h3">Book Services</h3>
          <p data-i18n="svc3_p">Find local experts for your projects. Direct contact. Direct trust. No middlemen, no delays.</p>
          <div class="kw-svc-foot">
            <span class="kw-tag" data-i18n="svc3_tag">Book Now</span>
            <span class="kw-arrow"><i class="bi bi-arrow-up-right"></i></span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== MARQUEE ===== -->
  <div class="kw-marquee">
    <div class="kw-marquee-track" id="marqueeTrack">
      <!-- filled by JS -->
    </div>
  </div>

</div>

<style>
  :root {
    --c-bg:       #f6f4f0;
    --c-surface:  #ffffff;
    --c-ink:      #1c1917;
    --c-muted:    #78716c;
    --c-border:   #e7e4df;
    --c-amber:    #d97706;
    --c-amber-lt: #fef3c7;
    --c-navy:     #1e3a5f;
    --c-navy-lt:  #e8edf4;
    --c-teal:     #0e7490;
    --c-teal-lt:  #e0f2fe;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--c-bg);
    color: var(--c-ink);
    font-family: 'Inter', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  .kw-wrap { overflow-x: hidden; }

  

  /* ──────────────────────────────────────
     LANGUAGE SWITCHER
  ────────────────────────────────────── */
  .lang-bar {
    position: fixed;
    top: 70px;
    right: 24px;
    z-index: 9999;
  }
  

  .lang-trigger {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 9px 16px;
    background: var(--c-navy);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(30,58,95,0.25);
    transition: background 0.2s, box-shadow 0.2s;
    letter-spacing: 0.3px;
  }
  .lang-trigger:hover { background: #162d4a; }
  .lang-trigger i { font-size: 0.9rem; }

  .lang-chevron {
    font-size: 0.65rem !important;
    transition: transform 0.25s ease;
  }
  .lang-chevron.open { transform: rotate(180deg); }

  .lang-dropdown {
    display: none;
    flex-direction: column;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 12px;
    padding: 6px;
    min-width: 160px;
    box-shadow: 0 12px 36px rgba(0,0,0,0.12);
    animation: langDrop 0.2s ease;
  }
  .lang-dropdown.open { display: flex; }

  @keyframes langDrop {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .lang-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border: none;
    border-radius: 8px;
    background: transparent;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--c-muted);
    cursor: pointer;
    text-align: left;
    transition: background 0.15s, color 0.15s;
  }
  .lang-option:hover { background: var(--c-bg); color: var(--c-ink); }
  .lang-option.active { color: var(--c-navy); font-weight: 700; }
  .lang-option.active .lang-dot { background: var(--c-amber); }

  .lang-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--c-border);
    flex-shrink: 0;
    transition: background 0.2s;
  }

  /* content fade during switch */
  .kw-wrap { transition: opacity 0.18s ease; }
  .kw-wrap.fading { opacity: 0; }

  /* ──────────────────────────────────────
     HERO
  ────────────────────────────────────── */
  .kw-hero { padding: 80px 0 70px; }
  .kw-hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .kw-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: 100px;
    padding: 8px 18px;
    font-size: 0.78rem; font-weight: 600;
    color: var(--c-muted); margin-bottom: 28px;
    letter-spacing: 0.2px;
  }
  .kw-badge i { color: var(--c-amber); font-size: 0.85rem; }

  .kw-heading {
    font-size: clamp(2.4rem, 4vw, 3.8rem);
    font-weight: 700; line-height: 1.15;
    letter-spacing: -0.03em; color: var(--c-ink); margin-bottom: 20px;
  }
  .kw-accent { color: var(--c-amber); }

  .kw-subtext {
    font-size: 1.05rem; color: var(--c-muted); line-height: 1.75;
    max-width: 460px; margin-bottom: 36px;
  }
  .kw-subtext strong { color: var(--c-ink); font-weight: 600; }

  .kw-cta-row { display: flex; align-items: center; gap: 28px; margin-bottom: 48px; }

  .kw-btn-primary {
    background: var(--c-navy); color: #fff;
    padding: 14px 32px; border-radius: 10px;
    text-decoration: none; font-size: 0.9rem; font-weight: 600;
    letter-spacing: 0.1px;
    transition: background 0.25s, transform 0.25s, box-shadow 0.25s;
  }
  .kw-btn-primary:hover {
    background: var(--c-amber); transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(217,119,6,0.2); color: #fff;
  }
  .kw-btn-text {
    color: var(--c-ink); text-decoration: none; font-size: 0.9rem; font-weight: 600;
    display: inline-flex; align-items: center; gap: 6px;
    border-bottom: 1.5px solid transparent; padding-bottom: 2px; transition: 0.2s;
  }
  .kw-btn-text:hover { color: var(--c-amber); border-color: var(--c-amber); }

  .kw-stats-row {
    display: flex; align-items: center;
    padding-top: 28px; border-top: 1px solid var(--c-border);
  }
  .kw-stat { flex: 1; }
  .kw-stat strong {
    display: block; font-size: 1.75rem; font-weight: 700; color: var(--c-ink);
    letter-spacing: -0.03em; line-height: 1; margin-bottom: 4px;
  }
  .kw-stat span {
    font-size: 0.72rem; font-weight: 500; color: var(--c-muted);
    text-transform: uppercase; letter-spacing: 0.8px;
  }
  .kw-stat-sep { width: 1px; height: 40px; background: var(--c-border); margin: 0 24px; }

  /* right cards */
  .kw-hero-right { display: flex; flex-direction: column; gap: 16px; }
  .kw-card {
    background: var(--c-surface); border: 1px solid var(--c-border);
    border-radius: 16px; padding: 28px 30px;
    transition: box-shadow 0.3s, transform 0.3s;
  }
  .kw-card:hover { box-shadow: 0 12px 32px rgba(0,0,0,0.07); transform: translateY(-3px); }

  .kw-card-eyebrow {
    font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 1.5px; color: var(--c-muted); margin-bottom: 14px;
  }
  .kw-card-icon {
    width: 48px; height: 48px; background: var(--c-amber-lt);
    border-radius: 12px; display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; color: var(--c-amber); margin-bottom: 16px;
  }
  .kw-card-main h3 {
    font-size: 1.35rem; font-weight: 700; line-height: 1.3;
    margin-bottom: 10px; letter-spacing: -0.02em;
  }
  .kw-card-main p { font-size: 0.88rem; color: var(--c-muted); line-height: 1.7; margin-bottom: 16px; }
  .kw-verified-badge {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.75rem; font-weight: 600; color: #065f46;
    background: #d1fae5; padding: 5px 12px; border-radius: 6px;
  }

  .kw-mini-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .kw-card-mini { padding: 20px 22px; display: flex; flex-direction: column; gap: 10px; }
  .kw-card-mini span { font-size: 0.82rem; font-weight: 600; color: var(--c-ink); }
  .kw-card-mini > i { font-size: 1.4rem; align-self: flex-end; }
  .kw-card-live { background: var(--c-navy); border-color: transparent; }
  .kw-card-live span { color: rgba(255,255,255,0.9); }
  .kw-card-live > i { color: rgba(255,255,255,0.4); }
  .kw-pulse {
    width: 8px; height: 8px; border-radius: 50%; background: #34d399;
    animation: kw-pulse 1.8s infinite;
  }
  @keyframes kw-pulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(52,211,153,.5); }
    50%      { box-shadow: 0 0 0 5px rgba(52,211,153,0); }
  }
  .kw-card-experts { background: var(--c-bg); }
  .kw-avatars { display: flex; margin-bottom: 4px; }
  .kw-avatars img {
    width: 34px; height: 34px; border-radius: 50%;
    border: 2px solid var(--c-bg); margin-right: -8px;
  }

  /* ── SERVICES ── */
  .kw-services {
    padding: 80px 0 90px; border-top: 1px solid var(--c-border);
    background: var(--c-surface);
  }
  .kw-services-inner { max-width: 1200px; margin: 0 auto; padding: 0 40px; }

  .kw-section-label {
    display: flex; align-items: center; gap: 12px;
    font-size: 0.72rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 2px; color: var(--c-muted); margin-bottom: 40px;
  }
  .kw-section-label span {
    display: inline-block; width: 24px; height: 2px;
    background: var(--c-amber); border-radius: 2px;
  }

  .kw-services-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }

  .kw-svc {
    border-radius: 16px; padding: 36px 32px; position: relative;
    transition: transform 0.3s, box-shadow 0.3s; cursor: pointer;
  }
  .kw-svc:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,.1); }
  .kw-svc-dark  { background: var(--c-navy); color: #fff; }
  .kw-svc-amber { background: var(--c-amber); color: #fff; }
  .kw-svc-light { background: var(--c-bg); color: var(--c-ink); border: 1px solid var(--c-border); }

  .kw-svc-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 28px; }
  .kw-svc-num { font-size: 0.72rem; font-weight: 700; letter-spacing: 1.5px; opacity: .35; }
  .kw-svc-ico {
    width: 44px; height: 44px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center; font-size: 1.3rem;
  }
  .kw-svc-dark .kw-svc-ico  { background: rgba(255,255,255,.1);  color: #93c5fd; }
  .kw-svc-amber .kw-svc-ico { background: rgba(255,255,255,.15); color: #fff; }
  .kw-svc-light .kw-svc-ico { background: var(--c-amber-lt); color: var(--c-amber); }

  .kw-svc h3 { font-size: 1.25rem; font-weight: 700; margin-bottom: 10px; letter-spacing: -0.02em; }
  .kw-svc p  { font-size: 0.88rem; line-height: 1.7; margin-bottom: 28px; }
  .kw-svc-dark p   { color: rgba(255,255,255,.6); }
  .kw-svc-amber p  { color: rgba(255,255,255,.75); }
  .kw-svc-light p  { color: var(--c-muted); }

  .kw-svc-foot { display: flex; justify-content: space-between; align-items: center; }
  .kw-tag { font-size: .68rem; font-weight: 600; letter-spacing: .5px; padding: 5px 12px; border-radius: 6px; }
  .kw-svc-dark .kw-tag  { background: rgba(255,255,255,.1);  color: rgba(255,255,255,.8); }
  .kw-svc-amber .kw-tag { background: rgba(255,255,255,.2);  color: #fff; }
  .kw-svc-light .kw-tag { background: var(--c-amber-lt); color: var(--c-amber); font-weight: 700; }

  .kw-arrow {
    width: 34px; height: 34px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: .9rem; transition: transform .25s;
  }
  .kw-svc-dark .kw-arrow  { background: rgba(255,255,255,.08); color: rgba(255,255,255,.6); }
  .kw-svc-amber .kw-arrow { background: rgba(255,255,255,.15); color: #fff; }
  .kw-svc-light .kw-arrow { background: var(--c-border); color: var(--c-ink); }
  .kw-svc:hover .kw-arrow { transform: rotate(45deg); }

  /* ── MARQUEE ── */
  .kw-marquee { background: var(--c-navy); padding: 18px 0; overflow: hidden; border-top: 2px solid var(--c-amber); }
  .kw-marquee-track {
    display: flex; align-items: center; white-space: nowrap;
    animation: kw-scroll 22s linear infinite; width: max-content;
  }
  .kw-marquee-track span {
    font-size: .75rem; font-weight: 600; letter-spacing: 1.5px;
    text-transform: uppercase; color: rgba(255,255,255,.5); padding: 0 20px;
  }
  .kw-marquee-track i { color: var(--c-amber); font-size: 1rem; opacity: .6; }
  @keyframes kw-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* ── RESPONSIVE ── */
  @media (max-width: 991px) {
    .kw-hero-inner { grid-template-columns: 1fr; gap: 48px; padding: 0 24px; }
    .kw-hero { padding: 56px 0 48px; }
    .kw-services-grid { grid-template-columns: 1fr; }
    .kw-services-inner { padding: 0 24px; }
    .lang-bar { top: 12px; right: 14px; }
  }
  @media (max-width: 600px) {
    .kw-cta-row { flex-direction: column; align-items: flex-start; gap: 16px; }
    .kw-stats-row { flex-wrap: wrap; gap: 16px; }
    .kw-stat-sep { display: none; }
    .kw-mini-row { grid-template-columns: 1fr; }

    .lang-bar {
    position: fixed;
    top: 80px;
    right: 24px;
    z-index: 9999;
  }
  }
  /* CTA Buttons Layout */
.kw-cta-row{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:18px;
  flex-wrap:wrap;
}

/* Join Network Link */
.kw-btn-text{
  display:inline-flex;
  align-items:center;
  gap:6px;
  font-weight:700;
  font-size:.9rem;
  color:var(--navy);
  text-decoration:none;
  transition:all .25s ease;
}

.kw-btn-text i{
  font-size:1rem;
  transition:transform .25s ease;
}

.kw-btn-text:hover{
  color:var(--amber);
}

.kw-btn-text:hover i{
  transform:translateX(4px);
}

/* ───────── MOBILE RESPONSIVE ───────── */
@media (max-width:768px){

  .kw-cta-row{
    flex-direction:column;
    gap:12px;
    width:100%;
  }

  .kw-btn-primary{
    width:100%;
    text-align:center;
  }

  .kw-btn-text{
    justify-content:center;
    width:100%;
    font-size:.88rem;
  }

}

/* SMALL PHONE OPTIMIZATION */
@media (max-width:420px){

  .kw-btn-text{
    font-size:.82rem;
  }

}
</style>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>AOS.init({ duration: 800, once: true, easing: 'ease-out-quad' });</script>

<!-- ════════════════════════════════════════════
     i18n TRANSLATIONS + CONTROLLER
════════════════════════════════════════════ -->
<script>
const i18n = {
  en: {
    badge:             "India's Verified Skill Network",
