// ── Marquee builder ──────────────────────────────────────
function buildMarquee(lang) {
  const words = i18n[lang].marquee;
  const doubled = [...words, ...words]; // seamless loop
  const track = document.getElementById('marqueeTrack');
  track.innerHTML = doubled.map(w =>
    `<span>${w}</span><i class="bi bi-dot"></i>`
  ).join('');
}

// ── Core switcher ────────────────────────────────────────
function setLanguage(lang) {
  const t = i18n[lang];
  if (!t) return;

  const wrap = document.querySelector('.kw-wrap');
  wrap.classList.add('fading');

  setTimeout(() => {
    // translate all keyed elements
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (t[key] !== undefined) el.textContent = t[key];
    });

    // update trigger label
    document.getElementById('langLabel').textContent = t.langLabel;

    // rebuild marquee
    buildMarquee(lang);

    // update active state on options
    document.querySelectorAll('.lang-option').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.lang === lang);
    });

    // persist
    try { localStorage.setItem('kw_lang', lang); } catch(e) {}

    wrap.classList.remove('fading');
  }, 180);

  closeLangMenu();
}

// ── Dropdown toggle ──────────────────────────────────────
function toggleLangMenu() {
  const dd = document.getElementById('langDropdown');
  const ch = document.getElementById('langChevron');
  const open = dd.classList.toggle('open');
  ch.classList.toggle('open', open);
}

function closeLangMenu() {
  document.getElementById('langDropdown').classList.remove('open');
  document.getElementById('langChevron').classList.remove('open');
}

// close on outside click
document.addEventListener('click', e => {
  if (!e.target.closest('.lang-bar')) closeLangMenu();
});

// ── Init ─────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  buildMarquee('en'); // default marquee
  let saved = 'en';
  try { saved = localStorage.getItem('kw_lang') || 'en'; } catch(e) {}
  if (saved !== 'en') setLanguage(saved);
});
</script>
