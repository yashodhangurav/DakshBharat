<% layout("/layouts/boilerplate.ejs") %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>
:root {
  --bg: #fdfdfc;
  --surface: #ffffff;
  --ink: #0f172a;
  --muted: #64748b;
  --border: #e2e8f0;
  --amber: #d97706;
  --amber-soft: #fffbeb;
  --navy: #0f172a;
  --navy-light: #1e293b;
  --ease: cubic-bezier(0.4, 0, 0.2, 1);
}

body {
  background-color: var(--bg);
  color: var(--ink);
  font-family: 'Inter', sans-serif;
  -webkit-font-smoothing: antialiased;
}

h2, .btn-artisan-auth, .label-pill, .side-bg-word {
  font-family: 'Plus Jakarta Sans', sans-serif;
}

/* ── LAYOUT STRUCTURE ── */
.auth-portal-wrapper {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}

.auth-card-artisan {
  width: 100%;
  max-width: 1000px;
  background: var(--surface);
  border-radius: 24px;
  overflow: hidden;
  display: flex;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
  border: 1px solid var(--border);
}

/* ── SIDE PANEL (LEFT) ── */
.artisan-auth-side {
  flex: 0 0 420px;
  background: var(--navy);
  padding: 60px;
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  color: white;
  overflow: hidden;
}

.side-bg-word {
  position: absolute;
  bottom: -10px;
  left: -10px;
  font-size: 8rem;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.03);
  letter-spacing: -5px;
  line-height: 1;
  pointer-events: none;
}

.auth-logo-badge {
  width: 48px; height: 48px;
  background: var(--amber);
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem;
  box-shadow: 0 10px 15px -3px rgba(217, 119, 6, 0.4);
  margin-bottom: 40px;
}

.auth-visual-content h2 {
  font-size: 2.5rem;
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 20px;
  position: relative;
  z-index: 1;
}

.serif-italic {
  color: var(--amber);
  font-style: italic;
  font-weight: 500;
}

.auth-visual-content p {
  font-size: 0.95rem;
  color: #94a3b8;
  line-height: 1.6;
  max-width: 300px;
  position: relative;
  z-index: 1;
}

/* ── FORM SIDE (RIGHT) ── */
.auth-form-side {
  flex: 1;
  padding: 60px 80px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.label-pill {
  display: inline-block;
  background: var(--amber-soft);
  color: var(--amber);
  padding: 6px 12px;
  border-radius: 6px;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 1px;
  margin-bottom: 16px;
}

.auth-form-side header h2 {
  font-size: 2rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  margin-bottom: 8px;
}

.text-terracotta { color: var(--amber); }

/* ── FORM ELEMENTS ── */
.form-label-artisan {
  font-weight: 600;
  font-size: 0.8rem;
  color: var(--navy-light);
  margin-bottom: 8px;
}

.input-artisan-group {
  position: relative;
}

.input-artisan-group i {
  position: absolute;
  left: 16px; top: 50%;
  transform: translateY(-50%);
  color: #94a3b8;
  font-size: 1rem;
}

.form-control-artisan {
  width: 100%;
  padding: 12px 16px 12px 45px;
  background: #f8fafc;
  border: 1px solid var(--border);
  border-radius: 12px;
  font-size: 0.9rem;
  color: var(--ink);
  transition: all 0.2s var(--ease);
}

.form-control-artisan:focus {
  background: #fff;
  border-color: var(--amber);
  box-shadow: 0 0 0 4px rgba(217, 119, 6, 0.1);
  outline: none;
}

/* ── CHECKBOX & LINKS ── */
.artisan-check .form-check-input:checked {
  background-color: var(--amber);
  border-color: var(--amber);
}

.reset-link {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--amber);
  text-decoration: none;
  transition: opacity 0.2s;
}

.reset-link:hover { opacity: 0.8; }

/* ── BUTTON ── */
.btn-artisan-auth {
  width: 100%;
  padding: 16px;
  background: var(--navy);
  color: white;
  border: none;
  border-radius: 12px;
  font-size: 1rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  cursor: pointer;
  transition: all 0.3s var(--ease);
  margin-top: 10px;
}

.btn-artisan-auth:hover {
  background: var(--amber);
  transform: translateY(-2px);
  box-shadow: 0 10px 20px -5px rgba(217, 119, 6, 0.4);
}

.auth-signup-link {
  text-align: center;
  margin-top: 32px;
  font-size: 0.9rem;
  color: var(--muted);
}

.auth-signup-link a {
  color: var(--amber);
  text-decoration: none;
  font-weight: 700;
}

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .artisan-auth-side { display: none; }
  .auth-form-side { padding: 50px 40px; }
  .auth-card-artisan { max-width: 500px; }
}

@media (max-width: 576px) {
  .auth-portal-wrapper { padding: 1rem; }
  .auth-form-side { padding: 32px 20px; }
}
</style>

<div class="auth-portal-wrapper">
  <div class="auth-card-artisan">
    
    <div class="artisan-auth-side">
      <div class="side-bg-word">BHARAT</div>
      <div class="auth-visual-content">
        <div class="nx-logo">
            <div class="nx-logo-inner">
              <span class="nx-logo-d">D</span>
              <span class="nx-logo-b">B</span>
            </div>
            <div class="nx-logo-notch"></div>
          </div><br>
        <h2>The <span class="serif-italic">Bharat</span> <br>Awaits.</h2>
        <p>Access your professional dashboard and manage your artisan presence in the marketplace.</p>
      </div>
    </div>

    <div class="auth-form-side">
      <header class="mb-5">
        <span class="label-pill">Authentication</span>
        <h2>Welcome <span class="text-terracotta">Back</span></h2>
        <p class="text-muted">Sign in to continue to your verified network.</p>
      </header>

      <form action="/login" method="POST" class="needs-validation" novalidate>
        
        <div class="mb-4">
          <label for="username" class="form-label-artisan">Username</label>
          <div class="input-artisan-group">
            <i class="bi bi-person"></i>
            <input type="text" id="username" name="username" class="form-control-artisan" placeholder="Enter your username" required />
          </div>
        </div>

        <div class="mb-4">
          <label for="password" class="form-label-artisan">Password</label>
          <div class="input-artisan-group">
            <i class="bi bi-shield-lock"></i>
            <input type="password" id="password" name="password" class="form-control-artisan" placeholder="••••••••" required />
          </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-5">
          <div class="form-check artisan-check">
            <input class="form-check-input" type="checkbox" id="rememberMe">
            <label class="form-check-label small fw-bold text-muted" for="rememberMe">Stay Signed In</label>
          </div>
          <a href="#" class="reset-link">Reset Access?</a>
        </div>

        <button type="submit" class="btn-artisan-auth">
          <span>Initialize Access</span>
          <i class="bi bi-arrow-right"></i>
        </button>

        <div class="auth-signup-link">
          New to the Gallery? <a href="/signup">Create Artisan Account</a>
        </div>

      </form>
    </div>
  </div>
</div>