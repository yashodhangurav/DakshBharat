<% layout("/layouts/boilerplate.ejs") %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

<style>
:root {
  --bg: #fdfdfc;
  --surface: #ffffff;
  --ink: #0f172a;
  --muted: #64748b;
  --border: #e2e8f0;
  --amber: #d97706;
  --amber-soft: #fffbeb;
  --navy: #0f172a;
  --navy-light: #1e293b;
  --ease: cubic-bezier(0.4, 0, 0.2, 1);
}

body {
  background-color: var(--bg);
  color: var(--ink);
  font-family: 'Inter', sans-serif;
  -webkit-font-smoothing: antialiased;
}

h2, h6, .btn-artisan-auth, .label-pill {
  font-family: 'Plus Jakarta Sans', sans-serif;
}

/* ── LAYOUT STRUCTURE ── */
.auth-portal-wrapper {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}

.auth-card-artisan {
  width: 100%;
  max-width: 1100px;
  background: var(--surface);
  border-radius: 24px;
  overflow: hidden;
  display: flex;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
  border: 1px solid var(--border);
}

/* ── SIDE PANEL (LEFT) ── */
.artisan-signup-side {
  flex: 0 0 400px;
  background: var(--navy);
  padding: 60px;
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: white;
}

.artisan-signup-side::before {
  content: '';
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background-image: radial-gradient(circle at 0% 0%, rgba(217, 119, 6, 0.15) 0%, transparent 50%);
  pointer-events: none;
}

.auth-logo-badge {
  width: 48px; height: 48px;
  background: var(--amber);
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem;
  box-shadow: 0 10px 15px -3px rgba(217, 119, 6, 0.4);
}

.auth-visual-content h2 {
  font-size: 2.5rem;
  font-weight: 800;
  line-height: 1.1;
  margin-top: 40px;
}

.serif-italic {
  color: var(--amber);
  font-style: italic;
  font-weight: 500;
}

.benefit-list {
  margin-top: 60px;
}

.benefit-list li {
  margin-bottom: 32px;
}

.benefit-list h6 {
  font-size: 0.95rem;
  font-weight: 700;
  margin-bottom: 4px;
}

.benefit-list p {
  font-size: 0.85rem;
  color: #94a3b8;
  line-height: 1.6;
}

/* ── FORM SIDE (RIGHT) ── */
.auth-form-side {
  flex: 1;
  padding: 60px 80px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.label-pill {
  display: inline-block;
  background: var(--amber-soft);
  color: var(--amber);
  padding: 6px 12px;
  border-radius: 6px;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 1px;
  margin-bottom: 16px;
}

.auth-form-side header h2 {
  font-size: 2rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  margin-bottom: 8px;
}

.text-terracotta { color: var(--amber); }

/* ── FORM ELEMENTS ── */
.form-label-artisan {
  font-weight: 600;
  font-size: 0.8rem;
  color: var(--navy-light);
  margin-bottom: 8px;
}

.input-artisan-group {
  position: relative;
  transition: transform 0.2s var(--ease);
}

.input-artisan-group i {
  position: absolute;
  left: 16px; top: 50%;
  transform: translateY(-50%);
  color: #94a3b8;
  font-size: 1rem;
}

.form-control-artisan,
.form-select-artisan {
  width: 100%;
  padding: 12px 16px 12px 45px;
  background: #f8fafc;
  border: 1px solid var(--border);
  border-radius: 12px;
  font-size: 0.9rem;
  color: var(--ink);
  transition: all 0.2s var(--ease);
}

.form-control-artisan:focus,
.form-select-artisan:focus {
  background: #fff;
  border-color: var(--amber);
  box-shadow: 0 0 0 4px rgba(217, 119, 6, 0.1);
  outline: none;
}

/* ── DYNAMIC SECTION ── */
.dynamic-section {
  background: #fdfaf3;
  border: 1px solid #fde68a;
  border-radius: 16px;
  padding: 24px;
  margin: 20px 0;
}

/* ── BUTTON ── */
.btn-artisan-auth {
  width: 100%;
  padding: 16px;
  background: var(--navy);
  color: white;
  border: none;
  border-radius: 12px;
  font-size: 1rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  cursor: pointer;
  transition: all 0.3s var(--ease);
  margin-top: 20px;
}

.btn-artisan-auth:hover {
  background: var(--amber);
  transform: translateY(-2px);
  box-shadow: 0 10px 20px -5px rgba(217, 119, 6, 0.4);
}

.auth-signin-link {
  text-align: center;
  margin-top: 24px;
  font-size: 0.9rem;
  color: var(--muted);
}

.auth-signin-link a {
  color: var(--amber);
  text-decoration: none;
  font-weight: 700;
}

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .artisan-signup-side { display: none; }
  .auth-form-side { padding: 40px; }
  .auth-card-artisan { max-width: 600px; }
}

@media (max-width: 576px) {
  .auth-portal-wrapper { padding: 1rem; }
  .auth-form-side { padding: 30px 20px; }
}


</style>

<div class="auth-portal-wrapper">
  <div class="auth-card-artisan">
    
    <div class="artisan-signup-side">
      <div class="auth-visual-content">

        <div class="nx-logo">
            <div class="nx-logo-inner">
              <span class="nx-logo-d">D</span>
              <span class="nx-logo-b">B</span>
            </div>
            <div class="nx-logo-notch"></div>
        </div>

        <h2>Forge Your <br><span class="serif-italic">Identity</span></h2>
        
        <ul class="benefit-list list-unstyled">
          <li>
            <div class="d-flex gap-3">
              <i class="bi bi-check2-circle text-terracotta fs-5"></i>
              <div>
                <h6>Company Account</h6>
                <p>Deploy jobs and source verified rural talent with ease.</p>
              </div>
            </div>
          </li>
          <li>
            <div class="d-flex gap-3">
              <i class="bi bi-check2-circle text-terracotta fs-5"></i>
              <div>
                <h6>Employee Account</h6>
                <p>Showcase skills and find premium work opportunities.</p>
              </div>
            </div>
          </li>
        </ul>
      </div>
      
      <p class="small opacity-50 mb-0">© 2026 Daksh Bharat Ecosystem. All rights reserved.</p>
    </div>

    <div class="auth-form-side">
      <header class="mb-5">
        <span class="label-pill">Registration</span>
        <h2>Join the <span class="text-terracotta">Daksh Bharat</span></h2>
        <p class="text-muted">One unified account for our entire skill ecosystem.</p>
      </header>

      <form action="/signup" method="POST" class="needs-validation" novalidate>
        <div class="row g-4 mb-4">
          <div class="col-md-6">
            <label for="username" class="form-label-artisan">Full Name / Username</label>
            <div class="input-artisan-group">
              <i class="bi bi-person"></i>
              <input type="text" id="username" name="username" class="form-control-artisan" placeholder="John Doe" required />
            </div>
          </div>
          <div class="col-md-6">
            <label for="email" class="form-label-artisan">Email Address</label>
            <div class="input-artisan-group">
              <i class="bi bi-envelope"></i>
              <input type="email" id="email" name="email" class="form-control-artisan" placeholder="john@nexus.com" required />
            </div>
          </div>
        </div>

        <div class="row g-4 mb-4">
          <div class="col-md-4">
            <label for="role" class="form-label-artisan">Platform Role</label>
            <div class="input-artisan-group">
              <i class="bi bi-briefcase"></i>
              <select class="form-select-artisan" id="role" name="role" required onchange="toggleFields()">
                <option value="">Select...</option>
                <option value="company">Company</option>
                <option value="employee">Employee</option>
                <option value="customer">Customer</option>
              </select>
            </div>
          </div>
          <div class="col-md-4">
            <label for="phone" class="form-label-artisan">Phone Number</label>
            <div class="input-artisan-group">
              <i class="bi bi-telephone"></i>
              <input type="tel" id="phone" name="phone" class="form-control-artisan" placeholder="+91 00000 00000" required />
            </div>
          </div>
          <div class="col-md-4">
            <label for="location" class="form-label-artisan">Work Location</label>
            <div class="input-artisan-group">
              <i class="bi bi-geo-alt"></i>
              <input type="text" id="location" name="location" class="form-control-artisan" placeholder="City, State" required />
            </div>
          </div>
        </div>

        <div id="company-fields" class="dynamic-section mb-4" style="display:none;">
          <h6 class="mb-3 text-uppercase small fw-bold text-muted">Business Details</h6>
          <div class="row g-3">
            <div class="col-md-6">
              <input type="text" name="companyName" class="form-control-artisan" placeholder="Official Business Name">
            </div>
            <div class="col-md-6">
              <input type="text" name="industry" class="form-control-artisan" placeholder="Industry Type">
            </div>
          </div>
        </div>

        <div id="employee-fields" class="dynamic-section mb-4" style="display:none;">
          <h6 class="mb-3 text-uppercase small fw-bold text-muted">Skill Portfolio</h6>
          <input type="text" name="skills" class="form-control-artisan" placeholder="Primary Skills (e.g. Wiring, Plumbing)">
        </div>

        <div class="mb-5">
          <label for="password" class="form-label-artisan">Secure Password</label>
          <div class="input-artisan-group">
            <i class="bi bi-shield-lock"></i>
            <input type="password" id="password" name="password" class="form-control-artisan" placeholder="••••••••" required />
          </div>
        </div>

        <button type="submit" class="btn-artisan-auth">
          <span>Create My Account</span>
          <i class="bi bi-arrow-right"></i>
        </button>

        <div class="auth-signin-link">
          Already part of the network? <a href="/login">Sign In</a>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
    function toggleFields() {
        const role = document.getElementById('role').value;
        const companyDiv = document.getElementById('company-fields');
        const employeeDiv = document.getElementById('employee-fields');

        companyDiv.style.display = (role === 'company') ? 'block' : 'none';
        employeeDiv.style.display = (role === 'employee') ? 'block' : 'none';
    }
</script>